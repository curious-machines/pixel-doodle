// PDC pixel kernel: solid teal color
// Demonstrates the simplest possible pixel kernel — no WGSL needed.

import { pack_rgb } from color

fn pixel(x: i32, y: i32, w: i32, h: i32) -> i32 {
    return pack_rgb(0, 180, 200)
}

fn frame() -> bool {
    var buf = pixel.render()
    display_buffer(buf)
    return false
}
