builtin const width: f32
builtin const height: f32

var pixels = Buffer.U32()
var kern = Kernel.Pixel("texture_test", "texture_test.wgsl")
var tex: i32 = 0

fn init() {
    tex = load_texture("img", "../../images/lake-2.jpg")
}

fn frame() {
    kern.output = Bind.Out(pixels)
    kern.run()
    pixels.display_buffer()
}
