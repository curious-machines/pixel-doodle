builtin const width: f32
builtin const height: f32

var pixels = Buffer(.U32, 0.0)
var kern = Kernel("texture_test", "texture_test.wgsl", .Pixel)
var tex: i32 = 0

fn init() {
    tex = load_texture("img", "../../images/lake-2.jpg")
}

fn frame() {
    pixels.bind("output", .Out)
    kern.run()
    pixels.display_buffer()
}
