builtin const width: f32
builtin const height: f32

var _buf_pixels: i32 = 0
var _kern: i32 = 0
var _tex: i32 = 0

fn init() {
    _buf_pixels = create_buffer("gpu_u32", 0.0)
    _kern = load_kernel("texture_test", "texture_test.wgsl", 0)
    _tex = load_texture("img", "../../images/lake-2.jpg")
}

fn frame() {
    bind_buffer("output", _buf_pixels, 1)
    run_kernel(_kern)
    display_buffer(_buf_pixels)
}
