// Solid red — PDC pipeline equivalent of solid_red.pdp
// Loads the same WGSL kernel and dispatches it via the host API.

builtin const width: f32
builtin const height: f32

var pixel_buf: i32 = 0
var kernel: i32 = 0

fn init() {
    pixel_buf = create_buffer("gpu_u32", 0.0)
    kernel = load_kernel("solid_red", "solid_red.wgsl", 0)
}

fn frame() {
    bind_buffer("output", pixel_buf, 1)
    run_kernel(kernel)
    display_buffer(pixel_buf)
}
