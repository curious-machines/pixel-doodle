// Solid red — PDC pipeline equivalent of solid_red.pdp
// Loads the same WGSL kernel and dispatches it via the host API.

builtin const width: f32
builtin const height: f32

var pixels: i32 = 0
var kern: i32 = 0

fn init() {
    pixels = Buffer(.U32, 0.0)
    kern = Kernel("solid_red", "solid_red.wgsl", .Pixel)
}

fn frame() {
    bind_buffer("output", pixels, 1)
    run_kernel(kern)
    display_buffer(pixels)
}
