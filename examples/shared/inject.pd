// Inject a value into a buffer within a circular radius around a point.
// Supports flat (direct assignment) and quadratic (additive falloff) modes.
//
// Parameters:
//   inject_x, inject_y: center point (typically mouse position)
//   radius: injection radius in pixels
//   value: value to write (flat) or add (quadratic)
//   falloff_quadratic: 0 = flat (overwrite), 1 = quadratic (additive, 1-d²/r² falloff)
//
// Usage in .pdp:
//   run inject(inject_x: mouse_x, inject_y: mouse_y, radius: 5.0, value: 0.5,
//              falloff_quadratic: 0) { target: buf, target_out: out buf }

kernel inject(px: u32, py: u32, width: u32, height: u32,
              inject_x: f64, inject_y: f64, radius: f64,
              value: f64, falloff_quadratic: u32) -> u32
  buffers(target: read, target_out: write)
{
    let x = px as f64;
    let y = py as f64;
    let dx = x - inject_x;
    let dy = y - inject_y;
    let d2 = dx * dx + dy * dy;
    let r2 = radius * radius;
    let current = buf_load(target, px, py);

    let result = if d2 <= r2 {
        if falloff_quadratic >= 1 {
            current + value * (1.0 - d2 / r2)
        } else {
            value
        }
    } else {
        current
    };

    buf_store(target_out, px, py, result);
    emit 0;
}
