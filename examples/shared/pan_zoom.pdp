# Standard pan/zoom key bindings with reset
builtin var center_x: f64
builtin var center_y: f64
builtin var zoom: f64

on keydown(left) center_x -= 0.02 / zoom
on keydown(right) center_x += 0.02 / zoom
on keydown(up) center_y -= 0.02 / zoom
on keydown(down) center_y += 0.02 / zoom
on keydown(plus) zoom *= 1.03
on keydown(minus) zoom /= 1.03
on keypress(0) {
  center_x = 0.0
  center_y = 0.0
  zoom = 1.0
}
on keypress(q) quit
