import { register_pan_zoom } from "../../shared/pan_zoom"

builtin var sample_index: u32

var pixels = Buffer.U32()
var accum = Buffer.Vec4F32()
var kern = Kernel.Pixel("cornell_2d", "cornell_2d.wgsl")
var max_samples: u32 = 256

fn init() {
    sample_index = 0
    register_pan_zoom()
}

fn frame() -> bool {
    kern.output = Bind.Out(pixels)
    kern.accum = Bind.Out(accum)
    kern.run()
    pixels.display_buffer()
    sample_index = sample_index + 1
    return sample_index < max_samples
}
