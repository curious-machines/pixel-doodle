fn box_sdf(px: f64, py: f64) -> f64 {
    let dx = abs(px - 0.05) - 0.3;
    let dy = abs(py) - 0.3;
    let qx = max(dx, 0.0);
    let qy = max(dy, 0.0);
    let outer = sqrt(qx * qx + qy * qy);
    let inner = min(max(dx, dy), 0.0);
    return outer + inner;
}

fn light_sdf(px: f64, py: f64) -> f64 {
    return length(px - -0.7, py - -0.5) - 0.06;
}

fn full_sdf(px: f64, py: f64) -> f64 {
    return min(box_sdf(px, py), light_sdf(px, py));
}

kernel cornell_2d(x: f64, y: f64, px: u32, py: u32, sample_index: u32) -> u32 {
    let light_x = -0.7;
    let light_y = -0.5;
    let light_r = 0.06;

    // Inside box → black
    let in_box = box_sdf(x, y) <= 0.0;

    // Random point on light circle for soft shadows
    let seed = hash(px, py);
    let seed2 = hash(seed, sample_index);
    let rng = hash(seed2, sample_index);
    let la_angle = norm(rng) * 6.283185307179586;
    let tgt_x = light_x + cos(la_angle) * light_r;
    let tgt_y = light_y + sin(la_angle) * light_r;

    // Direction and distance to target
    let to_x = tgt_x - x;
    let to_y = tgt_y - y;
    let to_dist = max(length(to_x, to_y), 0.0001);
    let di_dx = to_x / to_dist;
    let di_dy = to_y / to_dist;

    // March toward light
    let not_in_box = !in_box;
    while mrx = x, mry = y, mtot = 0.0, m_alive: bool = not_in_box {
        let md = abs(full_sdf(mrx, mry));
        let new_mtot = mtot + md;
        break_if md < 0.001 || new_mtot > to_dist || !m_alive;
        yield mrx + di_dx * md,
              mry + di_dy * md,
              mtot + md,
              m_alive;
    }

    // Brightness = emission * light_r / (π * distance) + ambient
    let hit_light = light_sdf(mrx, mry) <= 0.002;
    let bright = 60.0 * light_r / (3.141592653589793 * to_dist) + 0.08;
    let radiance = if hit_light { bright } else { 0.08 };

    // Reinhard tone map
    let mapped = radiance / (1.0 + radiance) * 255.0;
    let final_val = if in_box { 0.0 } else { max(mapped, 0.0) };
    let v = u32(final_val);
    emit pack_argb(v, v, v);
}
