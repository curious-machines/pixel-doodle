include "../../shared/pan_zoom.pdp"

pipeline pd {
  pixel kernel "light_transport_2d.pd"
  accumulate(samples: 512) {
    display light_transport_2d
  }
}

pipeline pdir {
  pixel kernel "light_transport_2d.pdir"
  accumulate(samples: 512) {
    display light_transport_2d
  }
}

pipeline gpu {
  pixel kernel "light_transport_2d.wgsl"
  display light_transport_2d
}
