fn gear_sdf(px: f64, py: f64, cx: f64, cy: f64, r: f64, teeth: f64, depth: f64) -> f64 {
    let dist = length(px - cx, py - cy);
    let angle = atan2(py - cy, px - cx);
    let wave = clamp(sin(teeth * angle) * 8.0, -1.0, 1.0);
    return dist - (r + wave * depth);
}

fn circle_sdf(px: f64, py: f64, cx: f64, cy: f64, r: f64) -> f64 {
    return length(px - cx, py - cy) - r;
}

fn scene_sdf(px: f64, py: f64) -> f64 {
    let d_g1 = gear_sdf(px, py, -0.45, 0.0, 0.5, 12.0, 0.06);
    let d_g2 = gear_sdf(px, py, 0.45, 0.0, 0.35, 8.0, 0.06);
    let d_g3 = gear_sdf(px, py, 0.0, -0.65, 0.25, 6.0, 0.05);
    let d_hub1 = circle_sdf(px, py, -0.45, 0.0, 0.15);
    let d_hub2 = circle_sdf(px, py, 0.45, 0.0, 0.10);
    let d_hub3 = circle_sdf(px, py, 0.0, -0.65, 0.08);
    let d_sp1 = circle_sdf(px, py, -0.72, 0.0, 0.06);
    let d_sp2 = circle_sdf(px, py, -0.18, 0.0, 0.06);
    let d_sp3 = circle_sdf(px, py, -0.45, 0.27, 0.06);
    let d_sp4 = circle_sdf(px, py, -0.45, -0.27, 0.06);
    let d_gears = min(min(d_g1, d_g2), d_g3);
    let d_holes = min(min(min(d_hub1, d_hub2), d_hub3),
                      min(min(d_sp1, d_sp2), min(d_sp3, d_sp4)));
    return max(d_gears, -d_holes);
}

fn light_sdf(px: f64, py: f64) -> f64 {
    return min(circle_sdf(px, py, 0.0, 0.8, 0.12),
               circle_sdf(px, py, -0.8, -0.3, 0.08));
}

fn full_scene_sdf(px: f64, py: f64) -> f64 {
    return min(scene_sdf(px, py), light_sdf(px, py));
}

kernel light_transport_2d(x: f64, y: f64, px: u32, py: u32, sample_index: u32) -> u32 {
    let d_pixel = scene_sdf(x, y);
    let in_gear = d_pixel <= 0.0;

    // Surface normal at pixel position
    let d0_xp = scene_sdf(x + 0.002, y);
    let d0_xn = scene_sdf(x - 0.002, y);
    let d0_yp = scene_sdf(x, y + 0.002);
    let d0_yn = scene_sdf(x, y - 0.002);
    let n0_len = max(length(d0_xp - d0_xn, d0_yp - d0_yn), 0.0001);
    let n0x = (d0_xp - d0_xn) / n0_len;
    let n0y = (d0_yp - d0_yn) / n0_len;

    // Project to surface + nudge outward
    let proj_dist = max(-d_pixel, 0.0) + 0.005;
    let start_x = x + n0x * proj_dist;
    let start_y = y + n0y * proj_dist;

    // Initial random direction in outward half-plane
    let seed = hash(px, py);
    let seed2 = hash(seed, sample_index);
    let n0_angle = atan2(n0y, n0x);
    let theta0 = n0_angle + norm(seed2) * 3.141592653589793 - 1.5707963267948966;
    let dx0 = cos(theta0);
    let dy0 = sin(theta0);
    let rng0 = hash(seed2, sample_index);

    // Per-gear albedo
    let d_g1_px = gear_sdf(x, y, -0.45, 0.0, 0.5, 12.0, 0.06);
    let d_g2_px = gear_sdf(x, y, 0.45, 0.0, 0.35, 8.0, 0.06);
    let in_g1_px = d_g1_px <= 0.0;
    let in_g2_px = d_g2_px <= 0.0;

    // Copper / silver / gold albedos
    let alb_r = if in_g2_px { 0.65 } else if in_g1_px { 0.75 } else { 0.8 };
    let alb_g = if in_g2_px { 0.68 } else if in_g1_px { 0.5 } else { 0.72 };
    let alb_b = if in_g2_px { 0.72 } else if in_g1_px { 0.35 } else { 0.35 };

    // Ambient base
    let amb_r = alb_r * 0.45;
    let amb_g = alb_g * 0.45;
    let amb_b = alb_b * 0.45;

    // Bounce loop
    while bounce: u32 = 0, rad_r = amb_r, rad_g = amb_g, rad_b = amb_b,
          thr_r = alb_r, thr_g = alb_g, thr_b = alb_b,
          ray_x = start_x, ray_y = start_y,
          ray_dx = dx0, ray_dy = dy0,
          rng = rng0, alive: bool = in_gear {
        break_if bounce >= 8u32 || !alive;

        // Inner ray march
        while mrx = ray_x, mry = ray_y, mtot = 0.0 {
            let md = abs(full_scene_sdf(mrx, mry));
            let new_mtot = mtot + md;
            break_if md < 0.001 || new_mtot > 2.0;
            yield mrx + ray_dx * md, mry + ray_dy * md, mtot + md;
        }

        // Classify hit
        let escaped = abs(full_scene_sdf(mrx, mry)) > 0.001;
        let hit_light = light_sdf(mrx, mry) <= 0.001;

        // Sky contribution
        let new_rad_r = if hit_light { rad_r + thr_r * 6.0 }
                        else if escaped { rad_r + thr_r * 0.5 } else { rad_r };
        let new_rad_g = if hit_light { rad_g + thr_g * 5.5 }
                        else if escaped { rad_g + thr_g * 0.5 } else { rad_g };
        let new_rad_b = if hit_light { rad_b + thr_b * 4.0 }
                        else if escaped { rad_b + thr_b * 0.55 } else { rad_b };

        let still_alive = !escaped && !hit_light;

        // Surface normal at hit point
        let nx_raw = scene_sdf(mrx + 0.002, mry) - scene_sdf(mrx - 0.002, mry);
        let ny_raw = scene_sdf(mrx, mry + 0.002) - scene_sdf(mrx, mry - 0.002);
        let n_len = max(length(nx_raw, ny_raw), 0.0001);
        let nx = nx_raw / n_len;
        let ny = ny_raw / n_len;

        // Lambertian bounce
        let new_rng = hash(rng, bounce);
        let n_angle = atan2(ny, nx);
        let new_theta = n_angle + norm(new_rng) * 3.141592653589793 - 1.5707963267948966;
        let new_dx = cos(new_theta);
        let new_dy = sin(new_theta);
        let cos_weight = max(new_dx * nx + new_dy * ny, 0.0);

        // Update throughput
        let final_thr_r = if still_alive { thr_r * alb_r * cos_weight } else { thr_r };
        let final_thr_g = if still_alive { thr_g * alb_g * cos_weight } else { thr_g };
        let final_thr_b = if still_alive { thr_b * alb_b * cos_weight } else { thr_b };

        // Next ray origin
        let final_ray_x = if still_alive { mrx + nx * 0.005 } else { ray_x };
        let final_ray_y = if still_alive { mry + ny * 0.005 } else { ray_y };
        let final_dx = if still_alive { new_dx } else { ray_dx };
        let final_dy = if still_alive { new_dy } else { ray_dy };

        yield bounce + 1u32, new_rad_r, new_rad_g, new_rad_b,
              final_thr_r, final_thr_g, final_thr_b,
              final_ray_x, final_ray_y, final_dx, final_dy,
              new_rng, still_alive;
    }

    // Reinhard tone map
    let r_mapped = max(rad_r / (1.0 + rad_r) * 255.0, 0.0);
    let g_mapped = max(rad_g / (1.0 + rad_g) * 255.0, 0.0);
    let b_mapped = max(rad_b / (1.0 + rad_b) * 255.0, 0.0);

    let r_f = if in_gear { r_mapped } else { 20.0 };
    let g_f = if in_gear { g_mapped } else { 22.0 };
    let b_f = if in_gear { b_mapped } else { 28.0 };

    emit rgb255(r_f, g_f, b_f);
}
