// 3D Raymarched Cylinder — ported from https://www.shadertoy.com/view/wdXGDr
// Iq's exact SDF for a cylinder between two arbitrary endpoints.
// Demonstrates vec3 math, raymarching, camera orbit, and lighting.

fn sign(x: f64) -> f64 {
    return if x > 0.0 { 1.0 } else { if x < 0.0 { -1.0 } else { 0.0 } };
}

// Exact SDF for a cylinder between endpoints a and b with radius r
fn sd_cylinder(p: vec3, a: vec3, b: vec3, r: f64) -> f64 {
    let ba = b - a;
    let pa = p - a;
    let baba = dot(ba, ba);
    let paba = dot(pa, ba);
    let x = length(pa * baba - ba * paba) - r * baba;
    let y = abs(paba - baba * 0.5) - baba * 0.5;
    let x2 = x * x;
    let y2 = y * y * baba;

    let d = if max(x, y) < 0.0 {
        -min(x2, y2)
    } else {
        (if x > 0.0 { x2 } else { 0.0 }) + (if y > 0.0 { y2 } else { 0.0 })
    };

    return sign(d) * sqrt(abs(d)) / baba;
}

fn map(p: vec3) -> f64 {
    return sd_cylinder(p,
        vec3(-0.2, -0.3, -0.1),
        vec3(0.3, 0.3, 0.4),
        0.2);
}

// Tetrahedron technique for SDF normals (iq)
fn calc_normal(p: vec3) -> vec3 {
    let eps = 0.0005;
    // e.xyy = ( 1,-1,-1) * 0.5773
    // e.yyx = (-1,-1, 1) * 0.5773
    // e.yxy = (-1, 1,-1) * 0.5773
    // e.xxx = ( 1, 1, 1) * 0.5773
    let k = 0.5773;
    let e1 = vec3( k, -k, -k);
    let e2 = vec3(-k, -k,  k);
    let e3 = vec3(-k,  k, -k);
    let e4 = vec3( k,  k,  k);
    let n = e1 * map(p + e1 * eps)
          + e2 * map(p + e2 * eps)
          + e3 * map(p + e3 * eps)
          + e4 * map(p + e4 * eps);
    return normalize(n);
}

kernel cylinder_3d(x: f64, y: f64, time: f64) -> u32 {
    let p = vec2(x, y);

    // Camera orbit
    let an = 0.5 * (time - 10.0);
    let ro = vec3(cos(an), 0.4, sin(an));
    let ta = vec3(0.0, 0.0, 0.0);

    // Camera matrix
    let ww = normalize(ta - ro);
    let uu = normalize(cross(ww, vec3(0.0, 1.0, 0.0)));
    let vv = cross(uu, ww);

    // View ray
    let rd = normalize(p.x * uu + p.y * vv + 1.5 * ww);

    // Raymarch
    let tmax = 3.0;
    while t = 0.0, i: u32 = 0 {
        let pos = ro + t * rd;
        let h = map(pos);
        break_if h < 0.0001 || t > tmax || i >= 256u32;
        yield t + h, i + 1u32;
    }

    // Shading
    let hit_pos = ro + t * rd;
    let nor = calc_normal(hit_pos);
    let dif = clamp(dot(nor, vec3(0.57703, 0.57703, 0.57703)), 0.0, 1.0);
    let amb = 0.5 + 0.5 * dot(nor, vec3(0.0, 1.0, 0.0));
    let lit = vec3(0.2, 0.3, 0.4) * amb + vec3(0.8, 0.7, 0.5) * dif;
    let col = if t < tmax { lit } else { vec3(0.0, 0.0, 0.0) };

    // Gamma
    let final_col = vec3(sqrt(col.x), sqrt(col.y), sqrt(col.z));
    emit rgb(final_col.x, final_col.y, final_col.z);
}
