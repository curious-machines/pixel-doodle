// ============================================================================
// 2D SDF Library — ported from iquilezles.org/articles/distfunctions2d/
// Uses vec2 types for point coordinates, dimensions, and edge vectors.
// ============================================================================

use "sdf_helpers.pd";

// --- Basic Shapes -----------------------------------------------------------

fn sd_circle(p: vec2, r: f64) -> f64 {
    return length(p) - r;
}

fn sd_box(p: vec2, b: vec2) -> f64 {
    let d = abs(p) - b;
    return length(max(d, vec2(0.0, 0.0))) + min(max(d.x, d.y), 0.0);
}

// r_tl = vec2(top-left, bottom-left), r_tr = vec2(top-right, bottom-right)
fn sd_rounded_box(p: vec2, b: vec2, r_tl: vec2, r_tr: vec2) -> f64 {
    let rs = if p.x > 0.0 { r_tr } else { r_tl };
    let r = if p.y > 0.0 { rs.x } else { rs.y };
    let q = abs(p) - b + vec2(r, r);
    return min(max(q.x, q.y), 0.0) + length(max(q, vec2(0.0, 0.0))) - r;
}

fn sd_chamfer_box(p: vec2, b: vec2, chamfer: f64) -> f64 {
    let a = abs(p) - b;
    // swap so x >= y
    let sx = if a.y > a.x { a.y } else { a.x };
    let sy = if a.y > a.x { a.x } else { a.y };
    let sy2 = sy + chamfer;
    let k = 1.0 - sqrt(2.0);
    return if sy2 < 0.0 && sy2 + sx * k < 0.0 { sx }
           else if sx < sy2 { (sx + sy2) * sqrt(0.5) }
           else { length(vec2(sx, sy2)) };
}

fn sd_segment(p: vec2, a: vec2, b: vec2) -> f64 {
    let pa = p - a;
    let ba = b - a;
    let h = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);
    return length(pa - h * ba);
}

fn sd_oriented_box(p: vec2, a: vec2, b: vec2, th: f64) -> f64 {
    let l = length(b - a);
    let d = (b - a) / l;
    // center and rotate: q = mat2(dx,-dy, dy,dx) * (p - center)
    let c = p - (a + b) * 0.5;
    // mat2(d.x,-d.y, d.y,d.x) in GLSL = col0=(d.x,-d.y), col1=(d.y,d.x)
    // result = col0*cx + col1*cy
    let qx = d.x * c.x + d.y * c.y;
    let qy = -d.y * c.x + d.x * c.y;
    let e = vec2(abs(qx) - l * 0.5, abs(qy) - th * 0.5);
    return length(max(e, vec2(0.0, 0.0))) + min(max(e.x, e.y), 0.0);
}

// --- Triangles --------------------------------------------------------------

fn sd_equilateral_triangle(p: vec2, r: f64) -> f64 {
    let k = sqrt(3.0);
    let ax = abs(p.x) - r;
    let ay = p.y + r / k;
    // if ax + k*ay > 0, rotate: (ax - k*ay, -k*ax - ay) / 2
    let bx = if ax + k * ay > 0.0 { (ax - k * ay) / 2.0 } else { ax };
    let by = if ax + k * ay > 0.0 { (-k * ax - ay) / 2.0 } else { ay };
    let cx = bx - clamp(bx, -2.0 * r, 0.0);
    let cy = by;
    return -length(vec2(cx, cy)) * sign(cy);
}

fn sd_isosceles_triangle(p: vec2, q: vec2) -> f64 {
    let apx = abs(p.x);
    let h1 = clamp((apx * q.x + p.y * q.y) / dot(q, q), 0.0, 1.0);
    let aa = vec2(apx - q.x * h1, p.y - q.y * h1);
    let h2 = clamp(apx / q.x, 0.0, 1.0);
    let bb = vec2(apx - q.x * h2, p.y - q.y);
    let s = -sign(q.y);
    let d1 = dot(aa, aa);
    let s1 = s * (apx * q.y - p.y * q.x);
    let d2 = dot(bb, bb);
    let s2 = s * (p.y - q.y);
    let md = if d1 < d2 { d1 } else { d2 };
    let ms = if d1 < d2 { s1 } else { s2 };
    return -sqrt(md) * sign(ms);
}

fn sd_triangle(p: vec2, p0: vec2, p1: vec2, p2: vec2) -> f64 {
    let e0 = p1 - p0;
    let e1 = p2 - p1;
    let e2 = p0 - p2;
    let v0 = p - p0;
    let v1 = p - p1;
    let v2 = p - p2;
    // edge 0 closest point
    let h0 = clamp(dot(v0, e0) / dot(e0, e0), 0.0, 1.0);
    let pq0 = v0 - h0 * e0;
    // edge 1 closest point
    let h1 = clamp(dot(v1, e1) / dot(e1, e1), 0.0, 1.0);
    let pq1 = v1 - h1 * e1;
    // edge 2 closest point
    let h2 = clamp(dot(v2, e2) / dot(e2, e2), 0.0, 1.0);
    let pq2 = v2 - h2 * e2;
    let s = sign(e0.x * e2.y - e0.y * e2.x);
    // min distance² and winding
    let d0 = dot(pq0, pq0);
    let w0 = s * (v0.x * e0.y - v0.y * e0.x);
    let d1 = dot(pq1, pq1);
    let w1 = s * (v1.x * e1.y - v1.y * e1.x);
    let d2 = dot(pq2, pq2);
    let w2 = s * (v2.x * e2.y - v2.y * e2.x);
    let md01 = if d0 < d1 { d0 } else { d1 };
    let mw01 = if d0 < d1 { w0 } else { w1 };
    let md = if md01 < d2 { md01 } else { d2 };
    let mw = if md01 < d2 { mw01 } else { w2 };
    return -sqrt(md) * sign(mw);
}

// --- Quadrilaterals ---------------------------------------------------------

fn sd_rhombus(p: vec2, b: vec2) -> f64 {
    let nb = vec2(b.x, -b.y);
    let a = abs(p);
    let h = clamp((nb.x * a.x + nb.y * a.y + nb.y * nb.y) / dot(nb, nb), 0.0, 1.0);
    let r = vec2(a.x - nb.x * h, a.y - nb.y * (h - 1.0));
    return length(r) * sign(r.x);
}

fn sd_trapezoid(p: vec2, r1: f64, r2: f64, he: f64) -> f64 {
    let k1 = vec2(r2, he);
    let k2 = vec2(r2 - r1, 2.0 * he);
    let apx = abs(p.x);
    // ca = closest on vertical edges
    let ca = vec2(apx - min(apx, if p.y < 0.0 { r1 } else { r2 }), abs(p.y) - he);
    // cb = closest on slanted edge
    let dp = vec2(apx - k1.x, p.y - k1.y);
    let t = clamp(dot(dp, -k2) / dot(k2, k2), 0.0, 1.0);
    let cb = vec2(apx - k1.x + k2.x * t, p.y - k1.y + k2.y * t);
    let s = if cb.x < 0.0 && ca.y < 0.0 { -1.0 } else { 1.0 };
    return s * sqrt(min(dot(ca, ca), dot(cb, cb)));
}

fn sd_parallelogram(p: vec2, wi: f64, he: f64, sk: f64) -> f64 {
    let e = vec2(sk, he);
    // p = (p.y<0.0)?-p:p
    let q = if p.y < 0.0 { -p } else { p };
    // w = q - e; w.x -= clamp(w.x,-wi,wi)
    let wx_raw = q.x - e.x;
    let wy = q.y - e.y;
    let wx = wx_raw - clamp(wx_raw, -wi, wi);
    let w = vec2(wx, wy);
    let d1 = dot(w, w);
    let d1s = -wy;
    // s = p.x*e.y - p.y*e.x
    let s = q.x * e.y - q.y * e.x;
    // p = (s<0.0)?-p:p
    let r = if s < 0.0 { -q } else { q };
    // v = p - vec2(wi,0)
    let vx = r.x - wi;
    let vy = r.y;
    // v -= e*clamp(dot(v,e)/dot(e,e),-1,1)
    let v = vec2(vx, vy);
    let t = clamp(dot(v, e) / dot(e, e), -1.0, 1.0);
    let v2 = v - t * e;
    let d2 = dot(v2, v2);
    let d2s = wi * he - abs(s);
    let md = if d1 < d2 { d1 } else { d2 };
    let ms = if d1 < d2 { d1s } else { d2s };
    return sqrt(md) * sign(-ms);
}

// --- Capsules / Segments ----------------------------------------------------

fn sd_uneven_capsule(p: vec2, r1: f64, r2: f64, h: f64) -> f64 {
    let apx = abs(p.x);
    let b = (r1 - r2) / h;
    let a = sqrt(1.0 - b * b);
    let k = apx * (-b) + p.y * a;
    return if k < 0.0 { length(vec2(apx, p.y)) - r1 }
           else if k > a * h { length(vec2(apx, p.y - h)) - r2 }
           else { apx * a + p.y * b - r1 };
}

// --- Regular Polygons -------------------------------------------------------

fn sd_pentagon(p: vec2, r: f64) -> f64 {
    let k = vec2(0.809016994, 0.587785252);
    let kz = 0.726542528;
    let apx = abs(p.x);
    // Reflect across first edge
    let d1 = (-k.x) * apx + k.y * p.y;
    let t1 = min(d1, 0.0);
    let bx = apx - 2.0 * t1 * (-k.x);
    let by = p.y - 2.0 * t1 * k.y;
    // Reflect across second edge
    let d2 = k.x * bx + k.y * by;
    let t2 = min(d2, 0.0);
    let cx = bx - 2.0 * t2 * k.x;
    let cy = by - 2.0 * t2 * k.y;
    // Clamp and offset
    let d = vec2(cx - clamp(cx, -r * kz, r * kz), cy - r);
    return length(d) * sign(d.y);
}

fn sd_hexagon(p: vec2, r: f64) -> f64 {
    let k = vec2(-0.866025404, 0.5);
    let kz = 0.577350269;
    let ap = abs(p);
    // Reflect
    let d1 = k.x * ap.x + k.y * ap.y;
    let t1 = min(d1, 0.0);
    let bx = ap.x - 2.0 * t1 * k.x;
    let by = ap.y - 2.0 * t1 * k.y;
    let d = vec2(bx - clamp(bx, -kz * r, kz * r), by - r);
    return length(d) * sign(d.y);
}

fn sd_octagon(p: vec2, r: f64) -> f64 {
    let k = vec2(-0.9238795325, 0.3826834323);
    let kz = 0.4142135623;
    let ap = abs(p);
    // First reflection
    let d1 = k.x * ap.x + k.y * ap.y;
    let t1 = min(d1, 0.0);
    let bx = ap.x - 2.0 * t1 * k.x;
    let by = ap.y - 2.0 * t1 * k.y;
    // Second reflection
    let d2 = (-k.x) * bx + k.y * by;
    let t2 = min(d2, 0.0);
    let cx = bx - 2.0 * t2 * (-k.x);
    let cy = by - 2.0 * t2 * k.y;
    let d = vec2(cx - clamp(cx, -kz * r, kz * r), cy - r);
    return length(d) * sign(d.y);
}

fn sd_hexagram(p: vec2, r: f64) -> f64 {
    let kx = -0.5;
    let ky = 0.8660254038;
    let kz = 0.5773502692;
    let kw = 1.7320508076;
    let ap = abs(p);
    // First reflection (k.xy)
    let d1 = kx * ap.x + ky * ap.y;
    let t1 = min(d1, 0.0);
    let bx = ap.x - 2.0 * t1 * kx;
    let by = ap.y - 2.0 * t1 * ky;
    // Second reflection (k.yx)
    let d2 = ky * bx + kx * by;
    let t2 = min(d2, 0.0);
    let cx = bx - 2.0 * t2 * ky;
    let cy = by - 2.0 * t2 * kx;
    let d = vec2(cx - clamp(cx, r * kz, r * kw), cy - r);
    return length(d) * sign(d.y);
}

fn sd_pentagram(p: vec2, r: f64) -> f64 {
    let k1x = 0.809016994;
    let k2x = 0.309016994;
    let k1y = 0.587785252;
    let k2y = 0.951056516;
    let k1z = 0.726542528;
    let apx = abs(p.x);
    // Reflect across v1 = (k1x, -k1y)
    let d1 = max(k1x * apx + (-k1y) * p.y, 0.0);
    let bx = apx - 2.0 * d1 * k1x;
    let by = p.y - 2.0 * d1 * (-k1y);
    // Reflect across v2 = (-k1x, -k1y)
    let d2 = max((-k1x) * bx + (-k1y) * by, 0.0);
    let cx = bx - 2.0 * d2 * (-k1x);
    let cy = by - 2.0 * d2 * (-k1y);
    let dx = abs(cx);
    let dy = cy - r;
    // v3 = (k2x, -k2y)
    let t = clamp((dx * k2x + dy * (-k2y)), 0.0, k1z * r);
    let e = vec2(dx - k2x * t, dy - (-k2y) * t);
    return length(e) * sign(dy * k2x - dx * (-k2y));
}

// --- Arcs / Pies / Rings ----------------------------------------------------

fn sd_pie(p: vec2, c: vec2, r: f64) -> f64 {
    let apx = abs(p.x);
    let l = length(vec2(apx, p.y)) - r;
    // closest point on pie edge
    let t = clamp((apx * c.x + p.y * c.y), 0.0, r);
    let m = length(vec2(apx - c.x * t, p.y - c.y * t));
    return max(l, m * sign(c.y * apx - c.x * p.y));
}

fn sd_cut_disk(p: vec2, r: f64, h: f64) -> f64 {
    let w = sqrt(r * r - h * h);
    let apx = abs(p.x);
    let s = max((h - r) * apx * apx + w * w * (h + r - 2.0 * p.y), h * apx - w * p.y);
    return if s < 0.0 { length(vec2(apx, p.y)) - r }
           else if apx < w { h - p.y }
           else { length(vec2(apx - w, p.y - h)) };
}

fn sd_arc(p: vec2, sc: vec2, ra: f64, rb: f64) -> f64 {
    let apx = abs(p.x);
    let inner = if sc.y * apx > sc.x * p.y { length(vec2(apx - sc.x * ra, p.y - sc.y * ra)) }
                else { abs(length(vec2(apx, p.y)) - ra) };
    return inner - rb;
}

fn sd_ring(p: vec2, n: vec2, r: f64, th: f64) -> f64 {
    let apx = abs(p.x);
    // Rotate: mat2(nx,ny,-ny,nx) * p  → col0=(nx,-ny), col1=(ny,nx)
    let q = vec2(n.x * apx + n.y * p.y, -n.y * apx + n.x * p.y);
    let d1 = abs(length(q) - r) - th * 0.5;
    let inner_y = max(0.0, abs(r - q.y) - th * 0.5);
    let d2 = length(vec2(q.x, inner_y)) * sign(q.x);
    return max(d1, d2);
}

fn sd_horseshoe(p: vec2, c: vec2, r: f64, w: vec2) -> f64 {
    let apx = abs(p.x);
    let l = length(vec2(apx, p.y));
    // Rotate: mat2(-cx, cy, cy, cx) → col0=(-cx,cy), col1=(cy,cx)
    let qx = -c.x * apx + c.y * p.y;
    let qy = c.y * apx + c.x * p.y;
    let rx = if qy > 0.0 || qx > 0.0 { qx } else { l * sign(-c.x) };
    let ry = if qx > 0.0 { qy } else { l };
    // p = vec2(p.x, abs(p.y-r)) - w
    let tx = rx - w.y;
    let ty = abs(ry - r) - w.x;
    return length(vec2(max(tx, 0.0), max(ty, 0.0))) + min(0.0, max(tx, ty));
}

// --- Moon / Vesica ----------------------------------------------------------

fn sd_moon(p: vec2, d: f64, ra: f64, rb: f64) -> f64 {
    let apy = abs(p.y);
    let a = (ra * ra - rb * rb + d * d) / (2.0 * d);
    let b = sqrt(max(ra * ra - a * a, 0.0));
    return if d * (p.x * b - apy * a) > d * d * max(b - apy, 0.0) {
        length(vec2(p.x - a, apy - b))
    } else {
        max(length(vec2(p.x, apy)) - ra, -(length(vec2(p.x - d, apy)) - rb))
    };
}

fn sd_vesica(p: vec2, w: f64, h: f64) -> f64 {
    let ap = abs(p);
    let d = 0.5 * (w * w - h * h) / h;
    // branch: w*apy < d*(apx - w)
    let use_branch1 = w * ap.y < d * (ap.x - w);
    let cx = if use_branch1 { 0.0 } else { -d };
    let cy = if use_branch1 { w } else { 0.0 };
    let cz = if use_branch1 { 0.0 } else { d + h };
    // return length(p - c.yx) - c.z  (note: c.yx = (cy, cx))
    return length(vec2(ap.x - cy, ap.y - cx)) - cz;
}

fn sd_oriented_vesica(p: vec2, a: vec2, b: vec2, w: f64) -> f64 {
    let r = 0.5 * length(b - a);
    let d = 0.5 * (r * r - w * w) / w;
    let v = (b - a) / r;
    let m = (b + a) * 0.5;
    // q = 0.5*abs(mat2(vy,vx,-vx,vy)*(p-c))
    // mat2 col0=(vy,-vx) col1=(vx,vy)
    let dp = p - m;
    let qx = 0.5 * abs(v.y * dp.x + v.x * dp.y);
    let qy = 0.5 * abs(-v.x * dp.x + v.y * dp.y);
    let use_branch1 = r * qx < d * (qy - r);
    let hx = if use_branch1 { 0.0 } else { -d };
    let hy = if use_branch1 { r } else { 0.0 };
    let hz = if use_branch1 { 0.0 } else { d + w };
    return length(vec2(qx - hx, qy - hy)) - hz;
}

// --- Egg / Heart ------------------------------------------------------------

fn sd_egg(p: vec2, he: f64, ra: f64, rb: f64, bu: f64) -> f64 {
    let r = 0.5 * (he + ra + rb) / bu;
    let da = r - ra;
    let db = r - rb;
    let yc = (db * db - da * da - he * he) / (2.0 * he);
    let xc = sqrt(da * da - yc * yc);
    let apx = abs(p.x);
    let k = p.y * xc - apx * yc;
    return if k > 0.0 && k < he * (apx + xc) { length(vec2(apx + xc, p.y + yc)) - r }
           else { min(length(vec2(apx, p.y)) - ra, length(vec2(apx, p.y - he)) - rb) };
}

fn sd_heart(p: vec2) -> f64 {
    let apx = abs(p.x);
    let t = max(apx + p.y, 0.0);
    let v1 = vec2(apx - 0.25, p.y - 0.75);
    let v2 = vec2(apx, p.y - 1.0);
    let v3 = vec2(apx - 0.5 * t, p.y - 0.5 * t);
    return if p.y + apx > 1.0 {
        sqrt(dot(v1, v1)) - sqrt(2.0) / 4.0
    } else {
        sqrt(min(dot(v2, v2), dot(v3, v3))) * sign(apx - p.y)
    };
}

// --- Crosses ----------------------------------------------------------------

fn sd_cross(p: vec2, b: vec2, r: f64) -> f64 {
    let ap = abs(p);
    // swap so x >= y
    let sx = if ap.y > ap.x { ap.y } else { ap.x };
    let sy = if ap.y > ap.x { ap.x } else { ap.y };
    let q = vec2(sx - b.x, sy - b.y);
    let k = max(q.y, q.x);
    let wx = if k > 0.0 { q.x } else { b.y - sy };
    let wy = if k > 0.0 { q.y } else { -k };
    return sign(k) * length(vec2(max(wx, 0.0), max(wy, 0.0))) + r;
}

fn sd_rounded_x(p: vec2, w: f64, r: f64) -> f64 {
    let ap = abs(p);
    let t = min(ap.x + ap.y, w) * 0.5;
    return length(vec2(ap.x - t, ap.y - t)) - r;
}

fn sd_rounded_cross(p: vec2, h: f64) -> f64 {
    let k = 0.5 * (h + 1.0 / h);
    let ap = abs(p);
    let va = vec2(ap.x - 1.0, ap.y - k);
    let vb = vec2(ap.x, ap.y - h);
    let vc = vec2(ap.x - 1.0, ap.y);
    return if ap.x < 1.0 && ap.y < ap.x * (k - h) + h {
        k - sqrt(dot(va, va))
    } else {
        sqrt(min(dot(vb, vb), dot(vc, vc)))
    };
}

// --- Star -------------------------------------------------------------------

fn sd_star(p: vec2, r: f64, n: u32, m: f64) -> f64 {
    let an = 3.141593 / (n as f64);
    let en = 3.141593 / m;
    let acs = vec2(cos(an), sin(an));
    let ecs = vec2(cos(en), sin(en));
    let bn = mod_f(atan2(p.x, p.y), 2.0 * an) - an;
    let l = length(p);
    let qx = l * cos(bn) - r * acs.x;
    let qy = abs(l * sin(bn)) - r * acs.y;
    let q = vec2(qx, qy);
    let t = clamp(-dot(q, ecs), 0.0, r * acs.y / ecs.y);
    let f = q + t * ecs;
    return length(f) * sign(f.x);
}

// --- Tunnel / Stairs --------------------------------------------------------

fn sd_tunnel(p: vec2, wh: vec2) -> f64 {
    let apx = abs(p.x);
    let npy = -p.y;
    let q = vec2(apx - wh.x, npy - wh.y);
    let d1 = dot(vec2(max(q.x, 0.0), q.y), vec2(max(q.x, 0.0), q.y));
    let qx2 = if npy > 0.0 { q.x } else { length(vec2(apx, npy)) - wh.x };
    let d2 = dot(vec2(qx2, max(q.y, 0.0)), vec2(qx2, max(q.y, 0.0)));
    let d = sqrt(min(d1, d2));
    return if max(q.x, q.y) < 0.0 { -d } else { d };
}

// --- Ellipse (exact) --------------------------------------------------------

fn sd_ellipse(p: vec2, ab: vec2) -> f64 {
    let ap = abs(p);
    // Ensure ab.x < ab.y by swapping if needed
    let swap = ap.x > ap.y;
    let ex = if swap { ap.y } else { ap.x };
    let ey = if swap { ap.x } else { ap.y };
    let eax = if swap { ab.y } else { ab.x };
    let eay = if swap { ab.x } else { ab.y };

    let l = eay * eay - eax * eax;
    let m = eax * ex / l;
    let m2 = m * m;
    let n = eay * ey / l;
    let n2 = n * n;
    let c = (m2 + n2 - 1.0) / 3.0;
    let c3 = c * c * c;
    let q = c3 + m2 * n2 * 2.0;
    let dd = c3 + m2 * n2;
    let g = m + m * n2;

    // Branch 1: dd < 0
    let h2a = acos(q / c3) / 3.0;
    let sa = cos(h2a);
    let ta = sin(h2a) * sqrt(3.0);
    let rxa = sqrt(abs(-c * (sa + ta + 2.0) + m2));
    let rya = sqrt(abs(-c * (sa - ta + 2.0) + m2));
    let co_a = (rya + sign(l) * rxa + abs(g) / (rxa * rya + 0.0000001) - m) / 2.0;
    // Branch 2: dd >= 0
    let h2b = 2.0 * m * n * sqrt(abs(dd));
    let sb = sign(q + h2b) * pow(abs(q + h2b), 1.0 / 3.0);
    let ub = sign(q - h2b) * pow(abs(q - h2b), 1.0 / 3.0);
    let rxb = -sb - ub - c * 4.0 + 2.0 * m2;
    let ryb = (sb - ub) * sqrt(3.0);
    let rmb = sqrt(rxb * rxb + ryb * ryb);
    let co_b = (ryb / sqrt(abs(rmb - rxb) + 0.0000001) + 2.0 * g / (rmb + 0.0000001) - m) / 2.0;
    let co = if dd < 0.0 { co_a } else { co_b };

    let r = vec2(eax * co, eay * sqrt(1.0 - co * co));
    return length(vec2(r.x - ex, r.y - ey)) * sign(ey - r.y);
}

// --- Parabola ---------------------------------------------------------------

fn sd_parabola(p: vec2, k: f64) -> f64 {
    let apx = abs(p.x);
    let ik = 1.0 / k;
    let pp = ik * (p.y - 0.5 * ik) / 3.0;
    let q = 0.25 * ik * ik * apx;
    let h = q * q - pp * pp * pp;
    let r_pos = pow(abs(q + sqrt(abs(h))), 1.0 / 3.0);
    let x_pos = r_pos + pp / (r_pos + 0.0000001);
    let r_neg = sqrt(abs(pp));
    let x_neg = 2.0 * r_neg * cos(acos(q / (abs(pp) * r_neg + 0.0000001)) / 3.0);
    let x = if h > 0.0 { x_pos } else { x_neg };
    return length(vec2(apx - x, p.y - k * x * x)) * sign(apx - x);
}

fn sd_parabola_wh(p: vec2, wi: f64, he: f64) -> f64 {
    let apx = abs(p.x);
    let ik = wi * wi / he;
    let pp = ik * (he - p.y - 0.5 * ik) / 3.0;
    let q = apx * ik * ik / 4.0;
    let h = q * q - pp * pp * pp;
    let r_pos = pow(abs(q + sqrt(abs(h))), 1.0 / 3.0);
    let x_pos = r_pos + pp / (r_pos + 0.0000001);
    let r_neg = sqrt(abs(pp));
    let x_neg = 2.0 * r_neg * cos(acos(q / (abs(pp) * r_neg + 0.0000001)) / 3.0);
    let x = if h > 0.0 { x_pos } else { x_neg };
    let xc = min(x, wi);
    return length(vec2(apx - xc, p.y - (he - xc * xc / ik))) * sign(ik * (p.y - he) + apx * apx);
}

// --- Bezier (quadratic) -----------------------------------------------------

fn sd_bezier(p: vec2, a_: vec2, b_: vec2, c_: vec2) -> f64 {
    // a = B - A, b = A - 2B + C, c = a*2, d = A - pos
    let aa = b_ - a_;
    let bb = a_ - 2.0 * b_ + c_;
    let cc = 2.0 * aa;
    let dd = a_ - p;
    let kk = 1.0 / dot(bb, bb);
    let kx = kk * dot(aa, bb);
    let ky = kk * (2.0 * dot(aa, aa) + dot(dd, bb)) / 3.0;
    let kz = kk * dot(dd, aa);
    let pp = ky - kx * kx;
    let p3 = pp * pp * pp;
    let q = kx * (2.0 * kx * kx - 3.0 * ky) + kz;
    let h = q * q + 4.0 * p3;
    // Branch 1: h >= 0
    let sh = sqrt(abs(h));
    let bz_ux = (sh - q) / 2.0;
    let bz_uy = (-sh - q) / 2.0;
    let bz_uvx = sign(bz_ux) * pow(abs(bz_ux), 1.0 / 3.0);
    let bz_uvy = sign(bz_uy) * pow(abs(bz_uy), 1.0 / 3.0);
    let bz_t = clamp(bz_uvx + bz_uvy - kx, 0.0, 1.0);
    let bz_r = dd + (cc + bz_t * bb) * bz_t;
    let res_pos = dot(bz_r, bz_r);
    // Branch 2: h < 0
    let bz_z = sqrt(abs(-pp));
    let bz_v = acos(q / (pp * bz_z * 2.0 + 0.0000001)) / 3.0;
    let bz_m = cos(bz_v);
    let bz_n = sin(bz_v) * 1.732050808;
    let bz_t1 = clamp((bz_m + bz_m) * bz_z - kx, 0.0, 1.0);
    let bz_t2 = clamp((-bz_n - bz_m) * bz_z - kx, 0.0, 1.0);
    let r1 = dd + (cc + bz_t1 * bb) * bz_t1;
    let r2 = dd + (cc + bz_t2 * bb) * bz_t2;
    let res_neg = min(dot(r1, r1), dot(r2, r2));
    let res = if h >= 0.0 { res_pos } else { res_neg };
    return sqrt(res);
}

// --- Blobby Cross -----------------------------------------------------------

fn sd_blobby_cross(p: vec2, he: f64) -> f64 {
    let ap = abs(p);
    // Rotate 45°: (|x-y|, 1-x-y) / sqrt(2)
    let rx = abs(ap.x - ap.y) / sqrt(2.0);
    let ry = (1.0 - ap.x - ap.y) / sqrt(2.0);
    let pp = (he - ry - 0.25 / he) / (6.0 * he);
    let q = rx / (he * he * 16.0);
    let h = q * q - pp * pp * pp;
    let bc_r_pos = sqrt(abs(h));
    let x_pos = pow(abs(q + bc_r_pos), 1.0 / 3.0) - pow(abs(q - bc_r_pos), 1.0 / 3.0) * sign(bc_r_pos - q);
    let bc_r_neg = sqrt(abs(pp));
    let x_neg = 2.0 * bc_r_neg * cos(acos(q / (abs(pp) * bc_r_neg + 0.0000001)) / 3.0);
    let x = if h > 0.0 { x_pos } else { x_neg };
    let xc = min(x, sqrt(2.0) / 2.0);
    let z = vec2(xc - rx, he * (1.0 - 2.0 * xc * xc) - ry);
    return length(z) * sign(z.y);
}

// --- Cool S -----------------------------------------------------------------

fn sd_cool_s(p: vec2) -> f64 {
    let six = if p.y < 0.0 { -p.x } else { p.x };
    let apx = abs(p.x);
    let apy = abs(p.y) - 0.2;
    let rex = apx - min(round(apx / 0.4), 0.4);
    let aby = abs(apy - 0.2) - 0.6;
    // d1
    let t1 = clamp(0.5 * (six - apy), 0.0, 0.2);
    let v1 = vec2(six - t1, -apy - t1);
    let d1 = dot(v1, v1);
    // d2
    let t2 = clamp(0.5 * (apx - aby), 0.0, 0.4);
    let v2 = vec2(apx - t2, -aby - t2);
    let d2 = dot(v2, v2);
    // d3
    let v3 = vec2(rex, apy - clamp(apy, 0.0, 0.4));
    let d3 = dot(v3, v3);

    let d = min(d1, min(d2, d3));
    let s = 2.0 * apx + aby + abs(aby + 0.4) - 0.4;
    return sqrt(d) * sign(s);
}

// --- Circle Wave ------------------------------------------------------------

fn sd_circle_wave(p: vec2, tb: f64, ra: f64) -> f64 {
    let tb2 = 3.1415927 * 5.0 / 6.0 * max(tb, 0.0001);
    let co = vec2(ra * sin(tb2), ra * cos(tb2));
    let mx = abs(mod_f(p.x, co.x * 4.0) - co.x * 2.0);
    let p1 = vec2(mx, p.y);
    let p2 = vec2(abs(mx - 2.0 * co.x), -p.y + 2.0 * co.y);
    let d1 = if co.y * p1.x > co.x * p1.y { length(p1 - co) }
             else { abs(length(p1) - ra) };
    let d2 = if co.y * p2.x > co.x * p2.y { length(p2 - co) }
             else { abs(length(p2) - ra) };
    return min(d1, d2);
}

// --- Hyperbola --------------------------------------------------------------

fn sd_hyperbola(p: vec2, k: f64, he: f64) -> f64 {
    let ap = abs(p);
    // Rotate 45°
    let rx = (ap.x - ap.y) / sqrt(2.0);
    let ry = (ap.x + ap.y) / sqrt(2.0);
    let x2 = rx * rx / 16.0;
    let y2 = ry * ry / 16.0;
    let r = k * (4.0 * k - rx * ry) / 12.0;
    let q = (x2 - y2) * k * k;
    let h = q * q + r * r * r;
    let hyp_m_neg = sqrt(abs(-r));
    let u_neg = hyp_m_neg * cos(acos(q / (r * hyp_m_neg + 0.0000001)) / 3.0);
    let hyp_m_pos = pow(abs(sqrt(abs(h)) - q), 1.0 / 3.0);
    let u_pos = (hyp_m_pos - r / (hyp_m_pos + 0.0000001)) / 2.0;
    let u = if h < 0.0 { u_neg } else { u_pos };
    let w = sqrt(u + x2);
    let b = k * ry - x2 * rx * 2.0;
    let t_raw = rx / 4.0 - w + sqrt(2.0 * x2 - u + b / w / 4.0);
    let t = max(t_raw, sqrt(he * he * 0.5 + k) - he / sqrt(2.0));
    let d = length(vec2(rx - t, ry - k / t));
    return if rx * ry < k { d } else { -d };
}

// --- Quadratic Circle -------------------------------------------------------

fn sd_quadratic_circle(p: vec2) -> f64 {
    let ap = abs(p);
    let ex = if ap.y > ap.x { ap.y } else { ap.x };
    let ey = if ap.y > ap.x { ap.x } else { ap.y };
    let a = ex - ey;
    let b = ex + ey;
    let c = (2.0 * b - 1.0) / 3.0;
    let h = a * a + c * c * c;
    let qc_sh = sqrt(abs(h));
    let t_pos = sign(qc_sh - a) * pow(abs(qc_sh - a), 1.0 / 3.0) - pow(qc_sh + a, 1.0 / 3.0);
    let qc_z = sqrt(abs(-c));
    let qc_v = acos(a / (c * qc_z + 0.0000001)) / 3.0;
    let t_neg = -qc_z * (cos(qc_v) + sin(qc_v) * 1.732050808);
    let t = if h >= 0.0 { t_pos } else { t_neg };
    let t2 = t * 0.5;
    let w = vec2(-t2 + 0.75 - t2 * t2 - ex, t2 + 0.75 - t2 * t2 - ey);
    return length(w) * sign(a * a * 0.5 + b - 1.5);
}

// --- Stairs (simplified — no matrix rotation for clarity) -------------------

fn sd_stairs(p: vec2, wh: vec2, n: f64) -> f64 {
    let ba = n * wh;
    // Distance to bottom and right edges
    let cx = clamp(p.x, 0.0, ba.x);
    let cy = clamp(p.y, 0.0, ba.y);
    let d_init_v1 = vec2(p.x - cx, p.y);
    let d_init_v2 = vec2(p.x - ba.x, p.y - cy);
    let d_init = min(dot(d_init_v1, d_init_v1), dot(d_init_v2, d_init_v2));
    let s = sign(max(-p.y, p.x - ba.x));
    let dia = length(wh);
    // Rotate p by step angle
    let rpx = (wh.x * p.x + wh.y * p.y) / dia;
    let rpy = (-wh.y * p.x + wh.x * p.y) / dia;
    let id = clamp(round(rpx / dia), 0.0, n - 1.0);
    let spx = rpx - id * dia;
    let spy = rpy;
    // Rotate back
    let npx = (wh.x * spx - wh.y * spy) / dia;
    let npy = (wh.y * spx + wh.x * spy) / dia;
    let hh = wh.y / 2.0;
    let fy = npy - hh;
    let s2 = if fy > hh * sign(npx) { 1.0 } else { s };
    let ux = if id < 0.5 || npx > 0.0 { npx } else { -npx };
    let uy = if id < 0.5 || npx > 0.0 { fy } else { -fy };
    let d2_v = vec2(ux, clamp(uy, -hh, hh) - uy);
    let d3_v = vec2(clamp(ux, 0.0, wh.x) - ux, uy - hh);
    let d2 = dot(d2_v, d2_v);
    let d3 = dot(d3_v, d3_v);
    return sqrt(min(d_init, min(d2, d3))) * s2;
}

// ============================================================================
// Demo kernel — uncomment one shape to visualize
// ============================================================================
//kernel sdf2d_demo(x: f64, y: f64, time: f64) -> u32 {
kernel sdf2d_demo(x: f64, y: f64) -> u32 {
    let p = vec2(x, y);
    let d = sd_heart(vec2(x, y * -1.0 + 0.5));
    // let d = sd_hexagon(p, 0.5);
    // let d = sd_star(p, 0.4, 5u32, 2.5);
    // let d = sd_box(p, vec2(0.5, 0.3));
    // let d = sd_moon(p, 0.3, 0.5, 0.4);

    // let height = 0.501 - 0.499 * cos(time * 1.1 + 0.0);
    // let radius = 0.100 + 0.100 * sin(time * 1.7 + 2.0);
    // let d = sd_rounded_cross(p, height) - radius;

    // Shadertoy-style visualization
    let out_r = if d > 0.0 { 0.9 } else { 0.65 };
    let out_g = if d > 0.0 { 0.6 } else { 0.85 };
    let out_b = if d > 0.0 { 0.3 } else { 1.0 };
    let fade = 1.0 - exp(-6.0 * abs(d));
    let ring = 0.8 + 0.2 * cos(150.0 * d);
    let edge = 1.0 - smoothstep(0.0, 0.01, abs(d));
    emit rgb(mix(out_r * fade * ring, 1.0, edge),
             mix(out_g * fade * ring, 1.0, edge),
             mix(out_b * fade * ring, 1.0, edge));
}
