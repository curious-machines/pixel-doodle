on key(left) center_x -= 0.1
on key(right) center_x += 0.1
on key(up) center_y -= 0.1
on key(down) center_y += 0.1
on key(plus) zoom *= 1.1
on key(minus) zoom /= 1.1

pipeline cpu {
  pixel kernel "sdf_flower.pd"
  display sdf_flower
}

pipeline gpu {
  pixel kernel "sdf_flower.wgsl"
  display sdf_flower
}
