// ============================================================================
// SDF Helpers — shared utilities for 2D and 3D SDF libraries
// ============================================================================

fn sign(x: f64) -> f64 {
    return if x > 0.0 { 1.0 } else if x < 0.0 { -1.0 } else { 0.0 };
}

// GLSL mod: x - y*floor(x/y)
fn mod_f(x: f64, y: f64) -> f64 {
    return x - y * floor(x / y);
}

// dot(v,v) convenience for vec2
fn dot2v(v: vec2<f64>) -> f64 {
    return dot(v, v);
}

// dot(v,v) convenience for vec3
fn dot3v(v: vec3<f64>) -> f64 {
    return dot(v, v);
}

// --- Boolean operations -----------------------------------------------------

fn opSmoothUnion(a: f64, b: f64, k: f64) -> f64 {
    let k4 = k * 4.0;
    let h = max(k4 - abs(a - b), 0.0);
    return min(a, b) - h * h * 0.25 / k4;
}

fn opSmoothSubtraction(a: f64, b: f64, k: f64) -> f64 {
    return -opSmoothUnion(a, -b, k);
}

fn opSmoothIntersection(a: f64, b: f64, k: f64) -> f64 {
    return -opSmoothUnion(-a, -b, k);
}
