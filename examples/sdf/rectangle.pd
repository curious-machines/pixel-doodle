fn sd_rectangle(px: f64, py: f64, bx: f64, by: f64) -> f64 {
    let dx = abs(px) - bx;
    let dy = abs(py) - by;

    let dx2 = max(dx, 0.0);
    let dy2 = max(dy, 0.0);

    return length(dx2, dy2) + min(max(dx, dy), 0.0);
}

kernel rectangle(x: f64, y: f64) -> u32 {
    let d = sd_rectangle(x, y, 0.5, 0.25);

    // Coloring: warm outside, cool inside
    let out_r = if d > 0.0 { 0.9 } else { 0.65 };
    let out_g = if d > 0.0 { 0.6 } else { 0.85 };
    let out_b = if d > 0.0 { 0.3 } else { 1.0 };

    // Distance-based darkening
    let fade = 1.0 - exp(-6.0 * abs(d));
    let r = out_r * fade;
    let g = out_g * fade;
    let b = out_b * fade;

    // Contour rings
    let ring = 0.8 + 0.2 * cos(150.0 * d);
    let r2 = r * ring;
    let g2 = g * ring;
    let b2 = b * ring;

    // White outline at d=0
    let edge = 1.0 - smoothstep(0.0, 0.01, abs(d));
    let r3 = mix(r2, 1.0, edge);
    let g3 = mix(g2, 1.0, edge);
    let b3 = mix(b2, 1.0, edge);

    emit rgb(r3, g3, b3);
}
