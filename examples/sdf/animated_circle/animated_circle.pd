// Animated pulsing circle — demonstrates the time parameter
kernel animated_circle(x: f64, y: f64, time: f64) -> u32 {
    let r = 0.4 + 0.15 * sin(time * 3.0);
    let d = length(x, y) - r;

    let out_r = if d > 0.0 { 0.9 } else { 0.65 };
    let out_g = if d > 0.0 { 0.6 } else { 0.85 };
    let out_b = if d > 0.0 { 0.3 } else { 1.0 };

    let fade = 1.0 - exp(-6.0 * abs(d));
    let ring = 0.8 + 0.2 * cos(150.0 * d);
    let edge = 1.0 - smoothstep(0.0, 0.01, abs(d));

    emit rgb(mix(out_r * fade * ring, 1.0, edge),
             mix(out_g * fade * ring, 1.0, edge),
             mix(out_b * fade * ring, 1.0, edge));
}
