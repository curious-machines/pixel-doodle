include "../../shared/pan_zoom.pdp"

pipeline pd {
  pixel kernel "sdf_rings.pd"
  accumulate(samples: 256) {
    run sdf_rings
    display
  }
}

pipeline pdir {
  pixel kernel "sdf_rings.pdir"
  accumulate(samples: 256) {
    run sdf_rings
    display
  }
}

pipeline gpu {
  pixel kernel "sdf_rings.wgsl"
  run sdf_rings
  display
}
