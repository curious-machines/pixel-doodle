import { register_pan_zoom } from "../../shared/pan_zoom"

var pixels = Buffer.U32()
var kern = Kernel.Pixel("sdf_rings", "sdf_rings.wgsl")

fn init() {
    set_max_samples(256)
    register_pan_zoom()
}

fn frame() -> bool {
    if is_converged() { return false }
    kern.output = Bind.Out(pixels)
    kern.run()
    pixels.display_buffer()
    accumulate_sample()
    display_accumulated()
    return false
}
