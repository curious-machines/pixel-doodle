// Shadertoy "SDF Circle" (3ltSW2) — ported to PD
// Original: https://www.shadertoy.com/view/3ltSW2

fn sd_circle(px: f64, py: f64, r: f64) -> f64 {
    return length(px, py) - r;
}

fn wobble(position: vec2, frequency: vec2, amount: vec2) -> vec2 { 
    let wx = sin(position.y * frequency.x) * amount.x;                                                                                   
    let wy = sin(position.x * frequency.y) * amount.y;                                                                                   
    let wobble = vec2(wx, wy);                                                                                                           
    return position + wobble;                                                                                                            
} 

kernel circle(x: f64, y: f64, time: f64) -> u32 {
    let pi = 3.14159265358979;
    let frequency = 5.0;
    let amount = 0.05;
    let offset = time % (pi * 2.0 / frequency);
    let p1 = vec2(x, y) + vec2(offset, offset);
    let p2 = wobble(p1, vec2(frequency, frequency), vec2(amount, amount));
    let p3 = p2 - vec2(offset, offset);
    let d = sd_circle(p3.x, p3.y, 0.5);

    // Coloring: warm outside, cool inside
    let out_r = if d > 0.0 { 0.9 } else { 0.65 };
    let out_g = if d > 0.0 { 0.6 } else { 0.85 };
    let out_b = if d > 0.0 { 0.3 } else { 1.0 };

    // Distance-based darkening
    let fade = 1.0 - exp(-6.0 * abs(d));
    let r = out_r * fade;
    let g = out_g * fade;
    let b = out_b * fade;

    // Contour rings
    let ring = 0.8 + 0.2 * cos(150.0 * d);
    let r2 = r * ring;
    let g2 = g * ring;
    let b2 = b * ring;

    // White outline at d=0
    let edge = 1.0 - smoothstep(0.0, 0.01, abs(d));
    let r3 = mix(r2, 1.0, edge);
    let g3 = mix(g2, 1.0, edge);
    let b3 = mix(b2, 1.0, edge);

    emit rgb(r3, g3, b3);
}
