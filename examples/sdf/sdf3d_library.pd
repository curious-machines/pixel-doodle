// ============================================================================
// 3D SDF Library — ported from iquilezles.org/articles/distfunctions/
// Uses vec3 for point coordinates and dimensions.
// ============================================================================

use "sdf_helpers.pd";

// --- Primitives (exact) -----------------------------------------------------

// Sphere centered at origin
fn sdSphere(p: vec3, r: f64) -> f64 {
    return length(p) - r;
}

// Axis-aligned box
fn sdBox(p: vec3, b: vec3) -> f64 {
    let q = abs(p) - b;
    return length(max(q, vec3(0.0, 0.0, 0.0))) + min(max(q.x, max(q.y, q.z)), 0.0);
}

// Rounded box
fn sdRoundBox(p: vec3, b: vec3, r: f64) -> f64 {
    let q = abs(p) - b + vec3(r, r, r);
    return length(max(q, vec3(0.0, 0.0, 0.0))) + min(max(q.x, max(q.y, q.z)), 0.0) - r;
}

// Box frame — hollow box edges
fn sdBoxFrame(p: vec3, b: vec3, e: f64) -> f64 {
    let pa = abs(p) - b;
    let q = abs(pa + vec3(e, e, e)) - vec3(e, e, e);
    let d1 = length(max(vec3(pa.x, q.y, q.z), vec3(0.0, 0.0, 0.0)))
           + min(max(pa.x, max(q.y, q.z)), 0.0);
    let d2 = length(max(vec3(q.x, pa.y, q.z), vec3(0.0, 0.0, 0.0)))
           + min(max(q.x, max(pa.y, q.z)), 0.0);
    let d3 = length(max(vec3(q.x, q.y, pa.z), vec3(0.0, 0.0, 0.0)))
           + min(max(q.x, max(q.y, pa.z)), 0.0);
    return min(min(d1, d2), d3);
}

// Torus (major radius tx, minor radius ty)
fn sdTorus(p: vec3, tx: f64, ty: f64) -> f64 {
    let q = vec2(length(vec2(p.x, p.z)) - tx, p.y);
    return length(q) - ty;
}

// Capped torus — sc = vec2(sin,cos) of aperture angle
fn sdCappedTorus(p: vec3, sc: vec2, ra: f64, rb: f64) -> f64 {
    let px = abs(p.x);
    let pxy = vec2(px, p.y);
    let k = if sc.y * px > sc.x * p.y { dot(pxy, sc) } else { length(pxy) };
    return sqrt(dot(p, p) + ra * ra - 2.0 * ra * k) - rb;
}

// Chain link
fn sdLink(p: vec3, le: f64, r1: f64, r2: f64) -> f64 {
    let q = vec3(p.x, max(abs(p.y) - le, 0.0), p.z);
    return length(vec2(length(vec2(q.x, q.y)) - r1, q.z)) - r2;
}

// Capsule between two endpoints
fn sdCapsule(p: vec3, a: vec3, b: vec3, r: f64) -> f64 {
    let pa = p - a;
    let ba = b - a;
    let h = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);
    return length(pa - ba * h) - r;
}

// Vertical capsule (base at origin, height h along +Y)
fn sdVerticalCapsule(p: vec3, h: f64, r: f64) -> f64 {
    let py = p.y - clamp(p.y, 0.0, h);
    let q = vec3(p.x, py, p.z);
    return length(q) - r;
}

// Vertical capped cylinder (centered at origin)
fn sdCappedCylinder(p: vec3, r: f64, h: f64) -> f64 {
    let d = abs(vec2(length(vec2(p.x, p.z)), p.y)) - vec2(r, h);
    return min(max(d.x, d.y), 0.0) + length(max(d, vec2(0.0, 0.0)));
}

// Capped cylinder between arbitrary endpoints a and b
fn sdCappedCylinderAB(p: vec3, a: vec3, b: vec3, r: f64) -> f64 {
    let ba = b - a;
    let pa = p - a;
    let baba = dot(ba, ba);
    let paba = dot(pa, ba);
    let x = length(pa * baba - ba * paba) - r * baba;
    let y = abs(paba - baba * 0.5) - baba * 0.5;
    let x2 = x * x;
    let y2 = y * y * baba;
    let d = if max(x, y) < 0.0 {
        -min(x2, y2)
    } else {
        (if x > 0.0 { x2 } else { 0.0 }) + (if y > 0.0 { y2 } else { 0.0 })
    };
    return sign(d) * sqrt(abs(d)) / baba;
}

// Rounded cylinder
fn sdRoundedCylinder(p: vec3, ra: f64, rb: f64, h: f64) -> f64 {
    let d = vec2(length(vec2(p.x, p.z)) - ra + rb, abs(p.y) - h + rb);
    return min(max(d.x, d.y), 0.0) + length(max(d, vec2(0.0, 0.0))) - rb;
}

// Finite cone — c = vec2(sin, cos) of angle, h = height
fn sdCone(p: vec3, c: vec2, h: f64) -> f64 {
    let q = vec2(c.x / c.y, -1.0) * h;
    let w = vec2(length(vec2(p.x, p.z)), p.y);
    let a = w - q * clamp(dot(w, q) / dot(q, q), 0.0, 1.0);
    let b = w - q * vec2(clamp(w.x / q.x, 0.0, 1.0), 1.0);
    let k = sign(q.y);
    let d = min(dot(a, a), dot(b, b));
    let s = max(k * (w.x * q.y - w.y * q.x), k * (w.y - q.y));
    return sqrt(d) * sign(s);
}

// Infinite plane with normal n and offset h
fn sdPlane(p: vec3, n: vec3, h: f64) -> f64 {
    return dot(p, n) + h;
}

// Hexagonal prism — h.x = edge length, h.y = half-height
fn sdHexPrism(p: vec3, h: vec2) -> f64 {
    let kx = -0.8660254;
    let ky = 0.5;
    let kz = 0.57735;
    let ap = abs(p);
    let kxy = vec2(kx, ky);
    let dkp = dot(kxy, vec2(ap.x, ap.y));
    let fac = 2.0 * min(dkp, 0.0);
    let apx2 = ap.x - fac * kx;
    let apy2 = ap.y - fac * ky;
    let cx = clamp(apx2, -kz * h.x, kz * h.x);
    let dx = length(vec2(apx2 - cx, apy2 - h.x)) * sign(apy2 - h.x);
    let dy = ap.z - h.y;
    let d = vec2(dx, dy);
    return min(max(d.x, d.y), 0.0) + length(max(d, vec2(0.0, 0.0)));
}

// Vertical capped cone (centered at origin, radii r1 at bottom, r2 at top)
fn sdCappedCone(p: vec3, h: f64, r1: f64, r2: f64) -> f64 {
    let q = vec2(length(vec2(p.x, p.z)), p.y);
    let k1 = vec2(r2, h);
    let k2 = vec2(r2 - r1, 2.0 * h);
    let ca_x = q.x - min(q.x, if q.y < 0.0 { r1 } else { r2 });
    let ca_y = abs(q.y) - h;
    let ca = vec2(ca_x, ca_y);
    let t = clamp(dot(k1 - q, k2) / dot(k2, k2), 0.0, 1.0);
    let cb = q - k1 + k2 * t;
    let s = if cb.x < 0.0 && ca.y < 0.0 { -1.0 } else { 1.0 };
    return s * sqrt(min(dot(ca, ca), dot(cb, cb)));
}

// Capped cone between arbitrary endpoints
fn sdCappedConeAB(p: vec3, a: vec3, b: vec3, ra: f64, rb: f64) -> f64 {
    let rba = rb - ra;
    let baba = dot(b - a, b - a);
    let papa = dot(p - a, p - a);
    let paba = dot(p - a, b - a) / baba;
    let x = sqrt(papa - paba * paba * baba);
    let cax = max(0.0, x - (if paba < 0.5 { ra } else { rb }));
    let cay = abs(paba - 0.5) - 0.5;
    let k = rba * rba + baba;
    let f = clamp((rba * (x - ra) + paba * baba) / k, 0.0, 1.0);
    let cbx = x - ra - f * rba;
    let cby = paba - f;
    let s = if cbx < 0.0 && cay < 0.0 { -1.0 } else { 1.0 };
    return s * sqrt(min(cax * cax + cay * cay * baba, cbx * cbx + cby * cby * baba));
}

// Solid angle — c = vec2(sin, cos) of angle
fn sdSolidAngle(p: vec3, c: vec2, ra: f64) -> f64 {
    let q = vec2(length(vec2(p.x, p.z)), p.y);
    let l = length(q) - ra;
    let m = length(q - c * clamp(dot(q, c), 0.0, ra));
    return max(l, m * sign(c.y * q.x - c.x * q.y));
}

// Cut sphere — sphere with bottom cut at height h
fn sdCutSphere(p: vec3, r: f64, h: f64) -> f64 {
    let w = sqrt(r * r - h * h);
    let q = vec2(length(vec2(p.x, p.z)), p.y);
    let s = max((h - r) * q.x * q.x + w * w * (h + r - 2.0 * q.y), h * q.x - w * q.y);
    // Three cases: inside, on cap, on sphere
    let d_sphere = length(q) - r;
    let d_cap = h - q.y;
    let d_edge = length(q - vec2(w, h));
    return if s < 0.0 { d_sphere } else if q.x < w { d_cap } else { d_edge };
}

// Cut hollow sphere
fn sdCutHollowSphere(p: vec3, r: f64, h: f64, t: f64) -> f64 {
    let w = sqrt(r * r - h * h);
    let q = vec2(length(vec2(p.x, p.z)), p.y);
    let d = if h * q.x < w * q.y { length(q - vec2(w, h)) } else { abs(length(q) - r) };
    return d - t;
}

// Death star — sphere ra with sphere rb scooped out at distance d along x
fn sdDeathStar(p: vec3, ra: f64, rb: f64, d: f64) -> f64 {
    let a2 = (ra * ra - rb * rb + d * d) / (2.0 * d);
    let b2 = sqrt(max(ra * ra - a2 * a2, 0.0));
    let q = vec2(p.x, length(vec2(p.y, p.z)));
    let d1 = length(q - vec2(a2, b2));
    let d2 = max(length(q) - ra, -(length(q - vec2(d, 0.0)) - rb));
    return if q.x * b2 - q.y * a2 > d * max(b2 - q.y, 0.0) { d1 } else { d2 };
}

// Vertical round cone (base r1 at origin, r2 at height h)
fn sdRoundCone(p: vec3, r1: f64, r2: f64, h: f64) -> f64 {
    let b = (r1 - r2) / h;
    let a = sqrt(1.0 - b * b);
    let q = vec2(length(vec2(p.x, p.z)), p.y);
    let k = dot(q, vec2(-b, a));
    return if k < 0.0 { length(q) - r1 }
           else if k > a * h { length(q - vec2(0.0, h)) - r2 }
           else { dot(q, vec2(a, b)) - r1 };
}

// Round cone between arbitrary endpoints
fn sdRoundConeAB(p: vec3, a: vec3, b: vec3, r1: f64, r2: f64) -> f64 {
    let ba = b - a;
    let l2 = dot(ba, ba);
    let rr = r1 - r2;
    let a2 = l2 - rr * rr;
    let il2 = 1.0 / l2;
    let pa = p - a;
    let y = dot(pa, ba);
    let z = y - l2;
    let pv = pa * l2 - ba * y;
    let x2 = dot(pv, pv);
    let y2 = y * y * l2;
    let z2 = z * z * l2;
    let k = sign(rr) * rr * rr * x2;
    return if sign(z) * a2 * z2 > k { sqrt(x2 + z2) * il2 - r2 }
           else if sign(y) * a2 * y2 < k { sqrt(x2 + y2) * il2 - r1 }
           else { (sqrt(x2 * a2 * il2) + y * rr) * il2 - r1 };
}

// Ellipsoid (approximate)
fn sdEllipsoid(p: vec3, r: vec3) -> f64 {
    let px = p.x / r.x;
    let py = p.y / r.y;
    let pz = p.z / r.z;
    let pr = vec3(px, py, pz);
    let px2 = p.x / (r.x * r.x);
    let py2 = p.y / (r.y * r.y);
    let pz2 = p.z / (r.z * r.z);
    let pr2 = vec3(px2, py2, pz2);
    let k0 = length(pr);
    let k1 = length(pr2);
    return k0 * (k0 - 1.0) / k1;
}

// Rhombus — la, lb = half diagonals, h = half thickness, ra = rounding
fn sdRhombus(p: vec3, la: f64, lb: f64, h: f64, ra: f64) -> f64 {
    let ap = abs(p);
    let f = clamp((la * ap.x - lb * ap.z + lb * lb) / (la * la + lb * lb), 0.0, 1.0);
    let w = vec2(ap.x, ap.z) - vec2(la, lb) * vec2(f, 1.0 - f);
    let q = vec2(length(w) * sign(w.x) - ra, ap.y - h);
    return min(max(q.x, q.y), 0.0) + length(max(q, vec2(0.0, 0.0)));
}

// Octahedron (exact)
fn sdOctahedron(p: vec3, s: f64) -> f64 {
    let ap = abs(p);
    let m = ap.x + ap.y + ap.z - s;
    // Select face — reorder components so q.x is smallest
    let qx = if 3.0 * ap.x < m { ap.x } else if 3.0 * ap.y < m { ap.y } else if 3.0 * ap.z < m { ap.z } else { 0.0 };
    let qy = if 3.0 * ap.x < m { ap.y } else if 3.0 * ap.y < m { ap.z } else if 3.0 * ap.z < m { ap.x } else { 0.0 };
    let qz = if 3.0 * ap.x < m { ap.z } else if 3.0 * ap.y < m { ap.x } else if 3.0 * ap.z < m { ap.y } else { 0.0 };
    let early = m * 0.57735027;
    let k = clamp(0.5 * (qz - qy + s), 0.0, s);
    let late = length(vec3(qx, qy - s + k, qz - k));
    return if 3.0 * ap.x >= m && 3.0 * ap.y >= m && 3.0 * ap.z >= m { early } else { late };
}

// Pyramid with unit square base, height h
fn sdPyramid(p: vec3, h: f64) -> f64 {
    let m2 = h * h + 0.25;
    // abs and conditional swap of xz
    let ax = abs(p.x);
    let az = abs(p.z);
    let pxs = if az > ax { az } else { ax };
    let pzs = if az > ax { ax } else { az };
    let pxs2 = pxs - 0.5;
    let pzs2 = pzs - 0.5;
    let qx = pzs2;
    let qy = h * p.y - 0.5 * pxs2;
    let qz = h * pxs2 + 0.5 * p.y;
    let s = max(-qx, 0.0);
    let t = clamp((qy - 0.5 * pzs2) / (m2 + 0.25), 0.0, 1.0);
    let a_val = m2 * (qx + s) * (qx + s) + qy * qy;
    let b_val = m2 * (qx + 0.5 * t) * (qx + 0.5 * t) + (qy - m2 * t) * (qy - m2 * t);
    let d2 = if min(qy, -qx * m2 - qy * 0.5) > 0.0 { 0.0 } else { min(a_val, b_val) };
    return sqrt((d2 + qz * qz) / m2) * sign(max(qz, -p.y));
}

// --- Unsigned Distances ------------------------------------------------------

// Unsigned distance to triangle
fn udTriangle(p: vec3, a: vec3, b: vec3, c: vec3) -> f64 {
    let ba = b - a;
    let pa = p - a;
    let cb = c - b;
    let pb = p - b;
    let ac = a - c;
    let pc = p - c;
    let nor = cross(ba, ac);
    let s1 = sign(dot(cross(ba, nor), pa));
    let s2 = sign(dot(cross(cb, nor), pb));
    let s3 = sign(dot(cross(ac, nor), pc));
    // Edge distances
    let t1 = clamp(dot(ba, pa) / dot(ba, ba), 0.0, 1.0);
    let e1 = ba * t1 - pa;
    let t2 = clamp(dot(cb, pb) / dot(cb, cb), 0.0, 1.0);
    let e2 = cb * t2 - pb;
    let t3 = clamp(dot(ac, pc) / dot(ac, ac), 0.0, 1.0);
    let e3 = ac * t3 - pc;
    let edge_dist = min(min(dot(e1, e1), dot(e2, e2)), dot(e3, e3));
    let face_dist = dot(nor, pa) * dot(nor, pa) / dot(nor, nor);
    return sqrt(if s1 + s2 + s3 < 2.0 { edge_dist } else { face_dist });
}

// Unsigned distance to quad
fn udQuad(p: vec3, a: vec3, b: vec3, c: vec3, d: vec3) -> f64 {
    let ba = b - a;
    let pa = p - a;
    let cb = c - b;
    let pb = p - b;
    let dc = d - c;
    let pc = p - c;
    let ad = a - d;
    let pd = p - d;
    let nor = cross(ba, ad);
    let s1 = sign(dot(cross(ba, nor), pa));
    let s2 = sign(dot(cross(cb, nor), pb));
    let s3 = sign(dot(cross(dc, nor), pc));
    let s4 = sign(dot(cross(ad, nor), pd));
    // Edge distances
    let t1 = clamp(dot(ba, pa) / dot(ba, ba), 0.0, 1.0);
    let e1 = ba * t1 - pa;
    let t2 = clamp(dot(cb, pb) / dot(cb, cb), 0.0, 1.0);
    let e2 = cb * t2 - pb;
    let t3 = clamp(dot(dc, pc) / dot(dc, dc), 0.0, 1.0);
    let e3 = dc * t3 - pc;
    let t4 = clamp(dot(ad, pd) / dot(ad, ad), 0.0, 1.0);
    let e4 = ad * t4 - pd;
    let edge_dist = min(min(min(dot(e1, e1), dot(e2, e2)), dot(e3, e3)), dot(e4, e4));
    let face_dist = dot(nor, pa) * dot(nor, pa) / dot(nor, nor);
    return sqrt(if s1 + s2 + s3 + s4 < 3.0 { edge_dist } else { face_dist });
}

// --- Demo: Raymarched scene -------------------------------------------------

fn map(p: vec3) -> f64 {
    let d_box = sdRoundBox(p - vec3(0.0, 0.0, 0.0), vec3(0.3, 0.3, 0.3), 0.05);
    let d_sphere = sdSphere(p - vec3(0.5, 0.2, 0.0), 0.3);
    let d_torus = sdTorus(p - vec3(-0.3, 0.4, 0.3), 0.35, 0.1);
    let d1 = opSmoothUnion(d_box, d_sphere, 0.2);
    return opSmoothUnion(d1, d_torus, 0.2);
}

// Tetrahedron technique for SDF normals
fn calc_normal(p: vec3) -> vec3 {
    let eps = 0.0005;
    let k = 0.5773;
    let e1 = vec3( k, -k, -k);
    let e2 = vec3(-k, -k,  k);
    let e3 = vec3(-k,  k, -k);
    let e4 = vec3( k,  k,  k);
    let n = e1 * map(p + e1 * eps)
          + e2 * map(p + e2 * eps)
          + e3 * map(p + e3 * eps)
          + e4 * map(p + e4 * eps);
    return normalize(n);
}

kernel sdf3d_demo(x: f64, y: f64, time: f64) -> u32 {
    let p = vec2(x, y);

    // Camera orbit
    let an = 0.5 * time;
    let ro = vec3(1.5 * cos(an), 0.8, 1.5 * sin(an));
    let ta = vec3(0.0, 0.1, 0.0);

    // Camera matrix
    let ww = normalize(ta - ro);
    let uu = normalize(cross(ww, vec3(0.0, 1.0, 0.0)));
    let vv = cross(uu, ww);

    // View ray
    let rd = normalize(p.x * uu + p.y * vv + 1.5 * ww);

    // Raymarch
    let tmax = 5.0;
    while t = 0.0, i: u32 = 0 {
        let pos = ro + t * rd;
        let h = map(pos);
        break_if h < 0.0001 || t > tmax || i >= 256u32;
        yield t + h, i + 1u32;
    }

    // Shading
    let hit_pos = ro + t * rd;
    let nor = calc_normal(hit_pos);
    let sun_dir = vec3(0.57703, 0.57703, 0.57703);
    let dif = clamp(dot(nor, sun_dir), 0.0, 1.0);
    let amb = 0.5 + 0.5 * dot(nor, vec3(0.0, 1.0, 0.0));
    let lit = vec3(0.2, 0.3, 0.4) * amb + vec3(0.8, 0.7, 0.5) * dif;
    let col = if t < tmax { lit } else { vec3(0.05, 0.05, 0.1) };

    // Gamma
    let final_col = vec3(sqrt(col.x), sqrt(col.y), sqrt(col.z));
    emit rgb(final_col.x, final_col.y, final_col.z);
}
