# Distance field: circle centered at origin, radius 1.
# Inside = blue, outside = black.
kernel circle {
    x2: f64 = mul x x
    y2: f64 = mul y y
    dist2: f64 = add x2 y2
    one: f64 = const 1.0
    inside: bool = le dist2 one
    blue: u32 = const 200
    black: u32 = const 0
    r: u32 = const 0
    g: u32 = const 0
    b: u32 = select inside blue black
    pixel: u32 = pack_argb r g b
    emit pixel
}
