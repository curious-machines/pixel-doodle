// Initialize Gray-Scott U field: 1.0 everywhere with random rectangular spots of 0.5

kernel init_gray_scott_u(px: u32, py: u32, width: u32, height: u32) -> u32
  buffers(out: write)
{
    // Hash position to get pseudo-random value
    let h1 = px * 374761393u32 + py * 668265263u32;
    let h2 = h1 ^ (h1 >> 13u32);
    let h3 = h2 * 1274126177u32;
    let h4 = h3 ^ (h3 >> 16u32);
    let hf = (h4 & 65535u32) as f64 / 65536.0;

    // 2% of pixels seeded with spots
    let val = if hf < 0.02 { 0.5 } else { 1.0 };
    buf_store(out, px, py, val);
    emit 0;
}
