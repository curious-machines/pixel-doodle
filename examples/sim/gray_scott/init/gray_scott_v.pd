// Initialize Gray-Scott V field: 0.0 everywhere with circular spots of 0.25
// Same blob positions as U init so spots overlap.

fn hash_u32(n: u32) -> u32 {
    let a = n ^ (n >> 13);
    let b = a * 1274126177;
    return b ^ (b >> 16);
}

kernel init_gray_scott_v(px: u32, py: u32, width: u32, height: u32) -> u32
  buffers(out: write)
{
    let radius = 5.0;
    let r2 = radius * radius;

    // Check 8 random blob centers (same positions as U)
    while i: u32 = 0, v: f64 = 0.0 {
        break_if i >= 8;
        let hx = hash_u32(i * 2);
        let hy = hash_u32(i * 2 + 1);
        let cx = (hx & 65535) as f64 / 65536.0 * width as f64;
        let cy = (hy & 65535) as f64 / 65536.0 * height as f64;
        let dx = px as f64 - cx;
        let dy = py as f64 - cy;
        let d2 = dx * dx + dy * dy;
        let new_v = if d2 < r2 { 0.25 } else { v };
        yield i + 1, new_v;
    }

    buf_store(out, px, py, v);
    emit 0;
}
