// Gray-Scott reaction-diffusion simulation kernel — PD version
//
// Two chemicals U and V diffuse and react, producing organic patterns.
// Parameters: F=0.037, k=0.06, Du=0.21, Dv=0.105, dt=1.0

kernel gray_scott(px: u32, py: u32, width: u32, height: u32) -> u32
  buffers(u_in: read, v_in: read, u_out: write, v_out: write)
{
    // Toroidal neighbor coordinates
    let wm1 = width - 1;
    let hm1 = height - 1;
    let xm = (px + wm1) % width;
    let xp = (px + 1) % width;
    let ym = (py + hm1) % height;
    let yp = (py + 1) % height;

    // 5-point stencil for U
    let u_c = buf_load(u_in, px, py);
    let u_l = buf_load(u_in, xm, py);
    let u_r = buf_load(u_in, xp, py);
    let u_u = buf_load(u_in, px, ym);
    let u_d = buf_load(u_in, px, yp);

    // 5-point stencil for V
    let v_c = buf_load(v_in, px, py);
    let v_l = buf_load(v_in, xm, py);
    let v_r = buf_load(v_in, xp, py);
    let v_u = buf_load(v_in, px, ym);
    let v_d = buf_load(v_in, px, yp);

    // Laplacian: sum of neighbors - 4 * center
    let lap_u = u_l + u_r + u_u + u_d - 4.0 * u_c;
    let lap_v = v_l + v_r + v_u + v_d - 4.0 * v_c;

    // Reaction: u * v * v
    let uvv = u_c * v_c * v_c;

    // Gray-Scott update
    let F = 0.037;
    let k = 0.06;
    let Du = 0.21;
    let Dv = 0.105;

    let new_u = u_c + Du * lap_u - uvv + F * (1.0 - u_c);
    let new_v = v_c + Dv * lap_v + uvv - (F + k) * v_c;

    buf_store(u_out, px, py, new_u);
    buf_store(v_out, px, py, new_v);

    // Visualization: V concentration -> color ramp
    let v = clamp(new_v, 0.0, 1.0);

    // Quadrant 1: black -> blue (v < 0.25)
    let t1 = v / 0.25;
    let b1 = t1 * 255.0;

    // Quadrant 2: blue -> white (0.25 <= v < 0.5)
    let t2 = (v - 0.25) / 0.25;
    let rg2 = t2 * 255.0;

    // Quadrant 3: white -> orange (0.5 <= v < 0.75)
    let t3 = (v - 0.5) / 0.25;
    let g3 = (1.0 - 0.35 * t3) * 255.0;
    let b3 = (1.0 - t3) * 255.0;

    // Quadrant 4: orange -> bright (v >= 0.75)
    let t4 = (v - 0.75) / 0.25;
    let g4 = (0.65 - 0.25 * t4) * 255.0;
    let b4 = t4 * 0.1 * 255.0;

    let is_q1 = v < 0.25;
    let is_q2 = v < 0.5;
    let is_q3 = v < 0.75;

    // Q1 vs Q2
    let r_12 = select(is_q1, 0.0, rg2);
    let g_12 = select(is_q1, 0.0, rg2);
    let b_12 = select(is_q1, b1, 255.0);

    // Q3 vs Q4
    let g_34 = select(is_q3, g3, g4);
    let b_34 = select(is_q3, b3, b4);

    // Q1-2 vs Q3-4
    let r_f = select(is_q2, r_12, 255.0);
    let g_f = select(is_q2, g_12, g_34);
    let b_f = select(is_q2, b_12, b_34);

    emit pack_argb(u32(r_f), u32(g_f), u32(b_f));
}
