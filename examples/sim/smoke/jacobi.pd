// Smoke Jacobi pressure solver (one iteration) — PD version
//
// p_new = (p_left + p_right + p_up + p_down - divergence) / 4
// Boundary cells output zero pressure.

kernel smoke_jacobi(px: u32, py: u32, width: u32, height: u32) -> u32
  buffers(div_in: read, press_in: read, press_out: write)
{
    let wm1 = width - 1;
    let hm1 = height - 1;

    let is_edge = px == 0 || px == wm1 || py == 0 || py == hm1;

    // Neighbor coordinates (wrapped to avoid u32 underflow on BufLoad)
    let xl = (px + wm1) % width;
    let xr = (px + 1) % width;
    let yu = (py + hm1) % height;
    let yd = (py + 1) % height;

    let p_l = buf_load(press_in, xl, py);
    let p_r = buf_load(press_in, xr, py);
    let p_u = buf_load(press_in, px, yu);
    let p_d = buf_load(press_in, px, yd);
    let d = buf_load(div_in, px, py);

    let p_new = (p_l + p_r + p_u + p_d - d) * 0.25;
    let p_final = select(is_edge, 0.0, p_new);

    buf_store(press_out, px, py, p_final);

    emit pack_argb(0, 0, 0);
}
