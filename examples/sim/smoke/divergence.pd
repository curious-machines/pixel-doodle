// Smoke divergence kernel — PD version
//
// Computes central-difference divergence of the velocity field.
// Boundary cells output zero.

kernel smoke_divergence(px: u32, py: u32, width: u32, height: u32) -> u32
  buffers(vx_in: read, vy_in: read, div_out: write)
{
    let wm1 = width - 1u32;
    let hm1 = height - 1u32;
    let is_edge = px == 0u32 || px == wm1 || py == 0u32 || py == hm1;

    // Neighbor coordinates (wrapped to avoid u32 underflow)
    let xl = (px + wm1) % width;
    let xr = (px + 1u32) % width;
    let yu = (py + hm1) % height;
    let yd = (py + 1u32) % height;

    let vx_r = buf_load(vx_in, xr, py);
    let vx_l = buf_load(vx_in, xl, py);
    let vy_d = buf_load(vy_in, px, yd);
    let vy_u = buf_load(vy_in, px, yu);

    let div_val = (vx_r - vx_l + vy_d - vy_u) * 0.5;
    let div_final = select(is_edge, 0.0, div_val);

    buf_store(div_out, px, py, div_final);

    emit pack_argb(0u32, 0u32, 0u32);
}
