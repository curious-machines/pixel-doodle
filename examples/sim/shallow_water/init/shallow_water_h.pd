// Initialize shallow water height field: rest height 1.0 with a few random bumps

kernel init_shallow_water_h(px: u32, py: u32, width: u32, height: u32) -> u32
  buffers(out: write)
{
    let fx = f64(px) / f64(width);
    let fy = f64(py) / f64(height);

    // Central bump
    let dx1 = fx - 0.5;
    let dy1 = fy - 0.5;
    let d1 = dx1 * dx1 + dy1 * dy1;
    let bump1 = 0.3 * if d1 < 0.01 { 1.0 - d1 / 0.01 } else { 0.0 };

    // Off-center bump
    let dx2 = fx - 0.3;
    let dy2 = fy - 0.3;
    let d2 = dx2 * dx2 + dy2 * dy2;
    let bump2 = 0.2 * if d2 < 0.008 { 1.0 - d2 / 0.008 } else { 0.0 };

    let val = 1.0 + bump1 + bump2;
    buf_store(out, px, py, val);
    emit 0;
}
