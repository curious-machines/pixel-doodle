// PDC Stress Test — 1000 filled+stroked circles via PDC pipeline

builtin const width: f32
builtin const height: f32

var scene: i32 = 0
var rasterizer = Kernel("rasterize", "../shared/tile_raster.wgsl", .Sim)
var pixels = Buffer(.U32, 0.0)

fn init() {
    scene = load_scene("stress", "stress_scene.pdc")
}

fn frame() {
    run_scene(scene)
    scene_buffer(scene, "segments").bind("segments", .In)
    scene_buffer(scene, "seg_path_ids").bind("seg_path_ids", .In)
    scene_buffer(scene, "tile_offsets").bind("tile_offsets", .In)
    scene_buffer(scene, "tile_counts").bind("tile_counts", .In)
    scene_buffer(scene, "tile_indices").bind("tile_indices", .In)
    scene_buffer(scene, "path_colors").bind("path_colors", .In)
    scene_buffer(scene, "path_fill_rules").bind("path_fill_rules", .In)
    pixels.bind("pixels", .Out)
    rasterizer.set_arg("tile_size", 16.0)
    rasterizer.set_arg("tiles_x", scene_tiles_x(scene))
    rasterizer.set_arg("num_paths", scene_num_paths(scene))
    rasterizer.run()
    pixels.display_buffer()
}
