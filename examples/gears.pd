fn gear_sdf(px: f64, py: f64, cx: f64, cy: f64, r: f64, teeth: f64, depth: f64) -> f64 {
    let dist = length(px - cx, py - cy);
    let angle = atan2(py - cy, px - cx);
    let wave = clamp(sin(teeth * angle) * 8.0, -1.0, 1.0);
    return dist - (r + wave * depth);
}

fn circle_sdf(px: f64, py: f64, cx: f64, cy: f64, r: f64) -> f64 {
    return length(px - cx, py - cy) - r;
}

kernel gears(x: f64, y: f64) -> u32 {
    // Three interlocking gears
    let d_g1 = gear_sdf(x, y, -0.45, 0.0, 0.5, 12.0, 0.06);
    let d_g2 = gear_sdf(x, y, 0.45, 0.0, 0.35, 8.0, 0.06);
    let d_g3 = gear_sdf(x, y, 0.0, -0.65, 0.25, 6.0, 0.05);

    // Hub holes
    let d_hub1 = circle_sdf(x, y, -0.45, 0.0, 0.15);
    let d_hub2 = circle_sdf(x, y, 0.45, 0.0, 0.10);
    let d_hub3 = circle_sdf(x, y, 0.0, -0.65, 0.08);

    // Spoke holes in large gear
    let d_sp1 = circle_sdf(x, y, -0.72, 0.0, 0.06);
    let d_sp2 = circle_sdf(x, y, -0.18, 0.0, 0.06);
    let d_sp3 = circle_sdf(x, y, -0.45, 0.27, 0.06);
    let d_sp4 = circle_sdf(x, y, -0.45, -0.27, 0.06);

    // Union of gear bodies, then subtract holes
    let d_gears = min(min(d_g1, d_g2), d_g3);
    let d_holes = min(min(min(d_hub1, d_hub2), d_hub3),
                      min(min(d_sp1, d_sp2), min(d_sp3, d_sp4)));
    let d_final = max(d_gears, -d_holes);

    let in_gear = d_final <= 0.0;
    let in_g1 = d_g1 <= 0.0;
    let in_g2 = d_g2 <= 0.0;

    // Per-gear colors: copper / silver / gold
    let base_r = if in_g1 { 180.0 } else { 200.0 };
    let base_g = if in_g1 { 120.0 } else { 180.0 };
    let base_b = if in_g1 { 80.0 } else { 80.0 };
    let color_r = if in_g2 { 160.0 } else { base_r };
    let color_g = if in_g2 { 170.0 } else { base_g };
    let color_b = if in_g2 { 180.0 } else { base_b };

    // Edge highlight
    let edge_boost = exp(-abs(d_final) * 60.0) * 40.0;

    let r_f = if in_gear { min(color_r + edge_boost, 255.0) } else { 20.0 };
    let g_f = if in_gear { min(color_g + edge_boost, 255.0) } else { 22.0 };
    let b_f = if in_gear { min(color_b + edge_boost, 255.0) } else { 28.0 };

    emit rgb255(r_f, g_f, b_f);
}
