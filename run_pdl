#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: ./run <backend> <example> [--samples N]"
    echo "  backend: cranelift, llvm, gpu"
    echo "  example: gradient, checkerboard, circle, etc."
    exit 1
}

[[ $# -lt 2 ]] && usage

backend="$1"
example="$2"
shift 2
extra_args=("$@")

# Ensure llvm-sys can find LLVM on macOS (Homebrew) and Linux
if [[ -z "${LLVM_SYS_201_PREFIX:-}" ]]; then
    if command -v brew &>/dev/null; then
        llvm_prefix="$(brew --prefix llvm@20 2>/dev/null || brew --prefix llvm 2>/dev/null || true)"
        if [[ -n "$llvm_prefix" && -d "$llvm_prefix" ]]; then
            export LLVM_SYS_201_PREFIX="$llvm_prefix"
        fi
    fi
fi

case "$backend" in
    cranelift)
        features="cranelift-backend"
        kernel="examples/${example}.pdl"
        ;;
    llvm)
        features="llvm-backend"
        kernel="examples/${example}.pdl"
        ;;
    gpu)
        features="cranelift-backend"  # need some default backend to compile
        kernel="examples/${example}.wgsl"
        ;;
    *)
        echo "Unknown backend: $backend"
        usage
        ;;
esac

if [[ ! -f "$kernel" ]]; then
    echo "Kernel file not found: $kernel"
    exit 1
fi

exec cargo run --release --no-default-features --features "$features" -- --backend "$backend" --kernel "$kernel" ${extra_args[@]+"${extra_args[@]}"}
