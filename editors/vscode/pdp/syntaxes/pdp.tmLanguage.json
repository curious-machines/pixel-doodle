{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PDP",
  "scopeName": "source.pdp",
  "patterns": [
    { "include": "#comment" },
    { "include": "#pipeline-block" },
    { "include": "#title" },
    { "include": "#event-handler" },
    { "include": "#include-directive" },
    { "include": "#variable-declaration" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#boolean" },
    { "include": "#operator" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.pdp"
    },
    "title": {
      "match": "\\b(title)\\s*=\\s*(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.other.title.pdp" },
        "2": { "name": "string.quoted.double.pdp" }
      }
    },
    "pipeline-block": {
      "begin": "\\b(pipeline)(?:\\s+([a-zA-Z_][a-zA-Z0-9_]*))?\\s*\\{",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.pipeline.pdp" },
        "2": { "name": "entity.name.type.pipeline.pdp" }
      },
      "end": "^\\}",
      "patterns": [
        { "include": "#comment" },
        { "include": "#loop-block" },
        { "include": "#kernel-declaration" },
        { "include": "#buffer-declaration" },
        { "include": "#swap-statement" },
        { "include": "#accumulate-block" },
        { "include": "#on-click-block" },
        { "include": "#on-key-block" },
        { "include": "#display-statement" },
        { "include": "#run-expression" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#gpu-type" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },
    "kernel-declaration": {
      "patterns": [
        {
          "match": "\\b(pixel|sim|init)\\s+(kernel)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.other.kernel-type.pdp" },
            "2": { "name": "keyword.declaration.kernel.pdp" },
            "3": { "name": "entity.name.function.kernel.pdp" },
            "4": { "name": "string.quoted.double.pdp" }
          }
        },
        {
          "match": "\\b(pixel|sim|init)\\s+(kernel)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.other.kernel-type.pdp" },
            "2": { "name": "keyword.declaration.kernel.pdp" },
            "3": { "name": "string.quoted.double.pdp" }
          }
        }
      ]
    },
    "buffer-declaration": {
      "match": "\\b(buffer)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.buffer.pdp" },
        "2": { "name": "variable.other.buffer.pdp" }
      }
    },
    "swap-statement": {
      "match": "\\b(swap)\\b",
      "name": "keyword.control.swap.pdp"
    },
    "swap-arrow": {
      "match": "<->",
      "name": "keyword.operator.swap.pdp"
    },
    "loop-block": {
      "begin": "\\b(loop)\\s*\\([^)]*\\)\\s*\\{",
      "beginCaptures": {
        "1": { "name": "keyword.control.loop.pdp" }
      },
      "end": "\\}",
      "patterns": [
        { "include": "#comment" },
        { "include": "#swap-statement" },
        { "include": "#display-statement" },
        { "include": "#run-expression" },
        { "include": "#loop-block" },
        { "include": "#on-click-block" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },
    "accumulate-block": {
      "begin": "\\b(accumulate)\\s*\\([^)]*\\)\\s*\\{",
      "beginCaptures": {
        "1": { "name": "keyword.control.accumulate.pdp" }
      },
      "end": "\\}",
      "patterns": [
        { "include": "#comment" },
        { "include": "#display-statement" },
        { "include": "#run-expression" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },
    "on-click-block": {
      "begin": "\\b(on)\\s+(click)\\s*\\([^)]*\\)\\s*\\{",
      "beginCaptures": {
        "1": { "name": "keyword.control.event.pdp" },
        "2": { "name": "keyword.other.event-type.pdp" }
      },
      "end": "\\}",
      "patterns": [
        { "include": "#comment" },
        { "include": "#run-expression" },
        { "include": "#display-statement" },
        { "include": "#swap-statement" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },
    "on-key-block": {
      "begin": "\\b(on)\\s+(key)\\s*\\([^)]*\\)\\s*\\{",
      "beginCaptures": {
        "1": { "name": "keyword.control.event.pdp" },
        "2": { "name": "keyword.other.event-type.pdp" }
      },
      "end": "\\}",
      "patterns": [
        { "include": "#comment" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },
    "display-statement": {
      "match": "\\b(display)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.display.pdp" },
        "2": { "name": "entity.name.function.kernel-ref.pdp" }
      }
    },
    "run-expression": {
      "match": "\\b(run)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.run.pdp" },
        "2": { "name": "entity.name.function.kernel-ref.pdp" }
      }
    },
    "event-handler": {
      "match": "\\b(on)\\s+(key)\\s*\\(([a-zA-Z_][a-zA-Z0-9_]*|[0-9])\\)",
      "captures": {
        "1": { "name": "keyword.control.event.pdp" },
        "2": { "name": "keyword.other.event-type.pdp" },
        "3": { "name": "variable.parameter.key-name.pdp" }
      }
    },
    "include-directive": {
      "match": "\\b(include)\\s+(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.control.include.pdp" },
        "2": { "name": "string.quoted.double.pdp" }
      }
    },
    "variable-declaration": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*:\\s*(range)\\s*\\(",
      "captures": {
        "1": { "name": "variable.other.pdp" },
        "2": { "name": "support.function.range.pdp" }
      }
    },
    "gpu-type": {
      "match": "\\b(gpu)\\s*\\((f32|vec2f|vec3f|vec4f|i32|u32)\\)",
      "captures": {
        "1": { "name": "keyword.other.gpu.pdp" },
        "2": { "name": "storage.type.gpu.pdp" }
      }
    },
    "string": {
      "match": "\"[^\"]*\"",
      "name": "string.quoted.double.pdp"
    },
    "number": {
      "patterns": [
        {
          "match": "\\b\\d+\\.\\d+\\b",
          "name": "constant.numeric.float.pdp"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.pdp"
        }
      ]
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.pdp"
    },
    "operator": {
      "patterns": [
        {
          "match": "<->",
          "name": "keyword.operator.swap.pdp"
        },
        {
          "match": "\\.\\.(?!\\.)",
          "name": "keyword.operator.range.pdp"
        },
        {
          "match": "\\+=|-=|\\*=|/=",
          "name": "keyword.operator.assignment.compound.pdp"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.pdp"
        },
        {
          "match": "[+\\-*/]",
          "name": "keyword.operator.arithmetic.pdp"
        },
        {
          "match": "!",
          "name": "keyword.operator.logical.pdp"
        }
      ]
    },
    "identifier": {
      "match": "\\b(constant|iterations|samples|continuous|radius|value|falloff|wrap|out|target)\\b",
      "name": "variable.parameter.pdp"
    }
  }
}
