{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PDP",
  "scopeName": "source.pdp",
  "patterns": [
    { "include": "#comment" },
    { "include": "#pipeline-block" },
    { "include": "#title" },
    { "include": "#event-handler" },
    { "include": "#include-directive" },
    { "include": "#builtin-declaration" },
    { "include": "#variable-declaration" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#boolean" },
    { "include": "#operator" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.pdp"
    },
    "title": {
      "match": "\\b(title)\\s*=\\s*(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.other.title.pdp" },
        "2": { "name": "string.quoted.double.pdp" }
      }
    },
    "pipeline-block": {
      "begin": "\\b(pipeline)(?:\\s+([a-zA-Z_][a-zA-Z0-9_]*))?\\s*\\{",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.pipeline.pdp" },
        "2": { "name": "entity.name.type.pipeline.pdp" }
      },
      "end": "^\\}",
      "patterns": [
        { "include": "#comment" },
        { "include": "#init-block" },
        { "include": "#loop-block" },
        { "include": "#builtin-declaration" },
        { "include": "#kernel-declaration" },
        { "include": "#buffer-declaration" },
        { "include": "#texture-declaration" },
        { "include": "#swap-statement" },
        { "include": "#accumulate-block" },
        { "include": "#on-mouse-block" },
        { "include": "#display-statement" },
        { "include": "#run-expression" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#gpu-type" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },
    "kernel-declaration": {
      "patterns": [
        {
          "match": "\\b(pixel)\\s+(kernel)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.other.kernel-type.pdp" },
            "2": { "name": "keyword.declaration.kernel.pdp" },
            "3": { "name": "entity.name.function.kernel.pdp" },
            "4": { "name": "string.quoted.double.pdp" }
          }
        },
        {
          "match": "\\b(pixel)\\s+(kernel)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.other.kernel-type.pdp" },
            "2": { "name": "keyword.declaration.kernel.pdp" },
            "3": { "name": "string.quoted.double.pdp" }
          }
        },
        {
          "match": "\\b(kernel)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.declaration.kernel.pdp" },
            "2": { "name": "entity.name.function.kernel.pdp" },
            "3": { "name": "string.quoted.double.pdp" }
          }
        },
        {
          "match": "\\b(kernel)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.declaration.kernel.pdp" },
            "2": { "name": "string.quoted.double.pdp" }
          }
        }
      ]
    },
    "buffer-declaration": {
      "match": "\\b(buffer)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.buffer.pdp" },
        "2": { "name": "variable.other.buffer.pdp" }
      }
    },
    "texture-declaration": {
      "match": "\\b(texture)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*(file)\\s*\\(\\s*(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.declaration.texture.pdp" },
        "2": { "name": "variable.other.texture.pdp" },
        "3": { "name": "support.function.file.pdp" },
        "4": { "name": "string.quoted.double.pdp" }
      }
    },
    "swap-statement": {
      "match": "\\b(swap)\\b",
      "name": "keyword.control.swap.pdp"
    },
    "init-block": {
      "begin": "\\b(init)\\s*\\{",
      "beginCaptures": {
        "1": { "name": "keyword.control.init.pdp" }
      },
      "end": "\\}",
      "patterns": [
        { "include": "#comment" },
        { "include": "#swap-statement" },
        { "include": "#run-expression" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },
    "loop-block": {
      "begin": "\\b(loop)\\s*\\([^)]*\\)\\s*\\{",
      "beginCaptures": {
        "1": { "name": "keyword.control.loop.pdp" }
      },
      "end": "\\}",
      "patterns": [
        { "include": "#comment" },
        { "include": "#swap-statement" },
        { "include": "#display-statement" },
        { "include": "#run-expression" },
        { "include": "#loop-block" },
        { "include": "#on-mouse-block" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },
    "accumulate-block": {
      "begin": "\\b(accumulate)\\s*\\([^)]*\\)\\s*\\{",
      "beginCaptures": {
        "1": { "name": "keyword.control.accumulate.pdp" }
      },
      "end": "\\}",
      "patterns": [
        { "include": "#comment" },
        { "include": "#display-statement" },
        { "include": "#run-expression" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },
    "on-mouse-block": {
      "begin": "\\b(on)\\s+(mousedown|click|mouseup)\\s*\\{",
      "beginCaptures": {
        "1": { "name": "keyword.control.event.pdp" },
        "2": { "name": "keyword.other.event-type.pdp" }
      },
      "end": "\\}",
      "patterns": [
        { "include": "#comment" },
        { "include": "#run-expression" },
        { "include": "#display-statement" },
        { "include": "#swap-statement" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },
    "on-key-block": {
      "begin": "\\b(on)\\s+(keydown|keypress|keyup)\\s*\\([^)]*\\)\\s*\\{",
      "beginCaptures": {
        "1": { "name": "keyword.control.event.pdp" },
        "2": { "name": "keyword.other.event-type.pdp" }
      },
      "end": "\\}",
      "patterns": [
        { "include": "#comment" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },
    "display-statement": {
      "patterns": [
        {
          "match": "\\b(display)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.display.pdp" },
            "2": { "name": "variable.other.buffer.pdp" }
          }
        },
        {
          "match": "\\b(display)\\b",
          "name": "keyword.control.display.pdp"
        }
      ]
    },
    "run-expression": {
      "match": "\\b(run)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.run.pdp" },
        "2": { "name": "entity.name.function.kernel-ref.pdp" }
      }
    },
    "event-handler": {
      "match": "\\b(on)\\s+(keydown|keypress|keyup)\\s*\\(([a-zA-Z_][a-zA-Z0-9_]*|[0-9])\\)",
      "captures": {
        "1": { "name": "keyword.control.event.pdp" },
        "2": { "name": "keyword.other.event-type.pdp" },
        "3": { "name": "variable.parameter.key-name.pdp" }
      }
    },
    "include-directive": {
      "match": "\\b(include)\\s+(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.control.include.pdp" },
        "2": { "name": "string.quoted.double.pdp" }
      }
    },
    "builtin-declaration": {
      "match": "\\b(builtin)\\s+(const|var)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*:\\s*(u32|u64|f64|bool)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.builtin.pdp" },
        "2": { "name": "storage.modifier.pdp" },
        "3": { "name": "variable.other.builtin.pdp" },
        "4": { "name": "storage.type.pdp" }
      }
    },
    "variable-declaration": {
      "patterns": [
        {
          "match": "\\b(var|const)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*:\\s*(range)\\s*<\\s*(u32|u64|f32|f64|i32|i64|bool)\\s*>\\s*\\(",
          "captures": {
            "1": { "name": "storage.modifier.pdp" },
            "2": { "name": "variable.other.pdp" },
            "3": { "name": "support.function.range.pdp" },
            "4": { "name": "storage.type.pdp" }
          }
        },
        {
          "match": "\\b(var|const)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*:\\s*(u32|u64|f64|bool)\\b",
          "captures": {
            "1": { "name": "storage.modifier.pdp" },
            "2": { "name": "variable.other.pdp" },
            "3": { "name": "storage.type.pdp" }
          }
        },
        {
          "match": "\\b(var|const)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=",
          "captures": {
            "1": { "name": "storage.modifier.pdp" },
            "2": { "name": "variable.other.pdp" }
          }
        }
      ]
    },
    "gpu-type": {
      "patterns": [
        {
          "match": "\\b(gpu)\\s*\\(\\s*(vec[234])\\s*<\\s*(f32)\\s*>\\s*\\)",
          "captures": {
            "1": { "name": "keyword.other.gpu.pdp" },
            "2": { "name": "storage.type.gpu.pdp" },
            "3": { "name": "storage.type.gpu.pdp" }
          }
        },
        {
          "match": "\\b(gpu)\\s*\\(\\s*(f32|i32|u32)\\s*\\)",
          "captures": {
            "1": { "name": "keyword.other.gpu.pdp" },
            "2": { "name": "storage.type.gpu.pdp" }
          }
        }
      ]
    },
    "string": {
      "match": "\"[^\"]*\"",
      "name": "string.quoted.double.pdp"
    },
    "number": {
      "patterns": [
        {
          "match": "\\b\\d+\\.\\d+\\b",
          "name": "constant.numeric.float.pdp"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.pdp"
        }
      ]
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.pdp"
    },
    "operator": {
      "patterns": [
        {
          "match": "\\.\\.(?!\\.)",
          "name": "keyword.operator.range.pdp"
        },
        {
          "match": "\\+=|-=|\\*=|/=",
          "name": "keyword.operator.assignment.compound.pdp"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.pdp"
        },
        {
          "match": "[+\\-*/]",
          "name": "keyword.operator.arithmetic.pdp"
        },
        {
          "match": "!",
          "name": "keyword.operator.logical.pdp"
        }
      ]
    },
    "identifier": {
      "match": "\\b(constant|iterations|samples|radius|value|falloff|wrap|out|target|with|file|texture)\\b",
      "name": "variable.parameter.pdp"
    }
  }
}
