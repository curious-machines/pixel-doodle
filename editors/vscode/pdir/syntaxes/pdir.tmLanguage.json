{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PDIR",
  "scopeName": "source.pdir",
  "patterns": [
    { "include": "#comment" },
    { "include": "#use-directive" },
    { "include": "#kernel" },
    { "include": "#inline-def" },
    { "include": "#while-carry" },
    { "include": "#control" },
    { "include": "#statement" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.pdir"
    },
    "use-directive": {
      "match": "\\b(use)\\s+(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.control.import.pdir" },
        "2": { "name": "string.quoted.double.pdir" }
      }
    },
    "inline-def": {
      "match": "\\b(inline)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.declaration.function.pdir" },
        "2": { "name": "entity.name.function.pdir" }
      }
    },
    "kernel": {
      "match": "\\b(kernel)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.declaration.kernel.pdir" },
        "2": { "name": "entity.name.function.pdir" }
      }
    },
    "while-carry": {
      "match": "\\b(while)\\s+(carry)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.control.while.pdir" },
        "2": { "name": "keyword.control.carry.pdir" }
      }
    },
    "control": {
      "patterns": [
        {
          "match": "\\b(emit|cond|yield|return)\\b",
          "name": "keyword.control.pdir"
        },
        {
          "match": "->",
          "name": "keyword.operator.arrow.pdir"
        }
      ]
    },
    "statement": {
      "patterns": [
        { "include": "#type" },
        { "include": "#operator" },
        { "include": "#constant" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#variable-def" }
      ]
    },
    "type": {
      "patterns": [
        {
          "match": "\\b(vec[234]|mat[234])\\s*<\\s*(f32|f64|i8|u8|i16|u16|i32|u32|i64|u64)\\s*>",
          "captures": {
            "1": { "name": "storage.type.pdir" },
            "2": { "name": "storage.type.pdir" }
          }
        },
        {
          "match": "\\b(array)\\s*<",
          "captures": {
            "1": { "name": "storage.type.pdir" }
          }
        },
        {
          "match": "\\b(f32|f64|i8|u8|i16|u16|i32|u32|i64|u64|bool)\\b",
          "name": "storage.type.pdir"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "match": "(?<==\\s*)\\b(add|sub|mul|div|rem|min|max|neg|abs|sqrt|floor|ceil|sin|cos|tan|asin|acos|atan|atan2|exp|exp2|log|log2|log10|pow|round|trunc|fract)\\b",
          "name": "support.function.arithmetic.pdir"
        },
        {
          "match": "(?<==\\s*)\\b(bit_and|bit_or|bit_xor|shl|shr)\\b",
          "name": "support.function.bitwise.pdir"
        },
        {
          "match": "(?<==\\s*)\\b(and|or|not)\\b",
          "name": "support.function.logical.pdir"
        },
        {
          "match": "(?<==\\s*)\\b(eq|ne|lt|le|gt|ge)\\b",
          "name": "support.function.comparison.pdir"
        },
        {
          "match": "(?<==\\s*)\\b([a-z]\\d+_to_[a-z]\\d+(_norm)?)\\b",
          "name": "support.function.conversion.pdir"
        },
        {
          "match": "(?<==\\s*)\\b(const|select|pack_argb)\\b",
          "name": "support.function.builtin.pdir"
        },
        {
          "match": "(?<==\\s*)\\b(make_vec[234]|extract_[xyzw]|vec_add|vec_sub|vec_mul|vec_div|vec_min|vec_max|vec_neg|vec_abs|vec_normalize|vec_scale|vec_dot|vec_length|vec_cross)\\b",
          "name": "support.function.vector.pdir"
        },
        {
          "match": "(?<==\\s*)\\b(make_mat[234]|mat_mul_vec|mat_mul|mat_transpose|mat_col[0123])\\b",
          "name": "support.function.matrix.pdir"
        },
        {
          "match": "(?<==\\s*)\\b(struct_new|struct_get|struct_set|array_new|array_get|array_set)\\b",
          "name": "support.function.compound.pdir"
        }
      ]
    },
    "string": {
      "match": "\"[^\"]*\"",
      "name": "string.quoted.double.pdir"
    },
    "number": {
      "patterns": [
        {
          "match": "\\b\\d+\\.\\d+(f32|f64)\\b",
          "captures": {
            "1": { "name": "storage.type.pdir" }
          },
          "name": "constant.numeric.float.pdir"
        },
        {
          "match": "\\b\\d+\\.\\d+\\b",
          "name": "constant.numeric.float.pdir"
        },
        {
          "match": "\\b\\d+(i8|u8|i16|u16|i32|u32|i64|u64|f32|f64)\\b",
          "captures": {
            "1": { "name": "storage.type.pdir" }
          },
          "name": "constant.numeric.integer.pdir"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.pdir"
        }
      ]
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.pdir"
    },
    "variable-def": {
      "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*:",
      "captures": {
        "1": { "name": "variable.other.pdir" }
      }
    }
  }
}
