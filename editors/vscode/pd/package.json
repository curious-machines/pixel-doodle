{
  "name": "pd",
  "displayName": "PD (Pixel Doodle)",
  "description": "Syntax highlighting for PD (.pd) files",
  "version": "0.1.0",
  "publisher": "curious-machines",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "pd",
        "aliases": [
          "PD",
          "Pixel Doodle"
        ],
        "extensions": [
          ".pd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pd",
        "scopeName": "source.pd",
        "path": "./syntaxes/pd.tmLanguage.json"
      }
    ]
  }
}
