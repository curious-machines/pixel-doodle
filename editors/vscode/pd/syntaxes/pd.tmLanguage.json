{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PD",
  "scopeName": "source.pd",
  "patterns": [
    { "include": "#comment" },
    { "include": "#use-directive" },
    { "include": "#kernel" },
    { "include": "#function" },
    { "include": "#control" },
    { "include": "#statement" }
  ],
  "repository": {
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.pd"
    },
    "use-directive": {
      "match": "\\b(use)\\s+(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.control.import.pd" },
        "2": { "name": "string.quoted.double.pd" }
      }
    },
    "kernel": {
      "match": "\\b(kernel)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.declaration.kernel.pd" },
        "2": { "name": "entity.name.function.pd" }
      }
    },
    "function": {
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.declaration.function.pd" },
        "2": { "name": "entity.name.function.pd" }
      }
    },
    "control": {
      "patterns": [
        {
          "match": "\\b(while|if|else|break_if|yield|emit|return|let)\\b",
          "name": "keyword.control.pd"
        },
        {
          "match": "\\b(as)\\b",
          "name": "keyword.operator.cast.pd"
        },
        {
          "match": "->",
          "name": "keyword.operator.arrow.pd"
        }
      ]
    },
    "statement": {
      "patterns": [
        { "include": "#type" },
        { "include": "#builtin-function" },
        { "include": "#operator" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" }
      ]
    },
    "type": {
      "patterns": [
        {
          "match": "\\b(vec[234]|mat[234])\\s*<\\s*(f32|f64|i8|u8|i16|u16|i32|u32|i64|u64)\\s*>",
          "captures": {
            "1": { "name": "storage.type.pd" },
            "2": { "name": "storage.type.pd" }
          }
        },
        {
          "match": "\\b(array)\\s*<",
          "captures": {
            "1": { "name": "storage.type.pd" }
          }
        },
        {
          "match": "\\b(f32|f64|i8|u8|i16|u16|i32|u32|i64|u64|bool)\\b",
          "name": "storage.type.pd"
        },
        {
          "match": "\\b(struct)\\b",
          "name": "keyword.declaration.struct.pd"
        }
      ]
    },
    "builtin-function": {
      "match": "\\b(abs|sqrt|floor|ceil|sin|cos|tan|asin|acos|atan|atan2|exp|exp2|log|log2|log10|pow|round|trunc|fract|min|max|clamp|saturate|length|distance|mix|smoothstep|step|rgb|rgb255|gray|gray255|pack_argb|f64_to_u32|u32_to_f64|norm|select|hash|vec2|vec3|vec4|mat2|mat3|mat4|dot|normalize|cross|transpose|col)\\s*(?=\\()",
      "name": "support.function.builtin.pd"
    },
    "operator": {
      "patterns": [
        {
          "match": "&&|\\|\\|",
          "name": "keyword.operator.logical.pd"
        },
        {
          "match": "==|!=|<=|>=|<|>",
          "name": "keyword.operator.comparison.pd"
        },
        {
          "match": "<<|>>",
          "name": "keyword.operator.bitwise.pd"
        },
        {
          "match": "[+\\-*/%]",
          "name": "keyword.operator.arithmetic.pd"
        },
        {
          "match": "[&|^~]",
          "name": "keyword.operator.bitwise.pd"
        },
        {
          "match": "!",
          "name": "keyword.operator.logical.pd"
        }
      ]
    },
    "string": {
      "match": "\"[^\"]*\"",
      "name": "string.quoted.double.pd"
    },
    "number": {
      "patterns": [
        {
          "match": "\\b\\d+\\.\\d+(f32|f64)\\b",
          "captures": {
            "1": { "name": "storage.type.pd" }
          },
          "name": "constant.numeric.float.pd"
        },
        {
          "match": "\\b\\d+\\.\\d+\\b",
          "name": "constant.numeric.float.pd"
        },
        {
          "match": "\\b\\d+(i8|u8|i16|u16|i32|u32|i64|u64|f32|f64)\\b",
          "captures": {
            "1": { "name": "storage.type.pd" }
          },
          "name": "constant.numeric.integer.pd"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.pd"
        }
      ]
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.pd"
    }
  }
}
