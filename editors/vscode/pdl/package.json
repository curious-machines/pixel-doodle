{
  "name": "pdl",
  "displayName": "PDL (Pixel Doodle Language)",
  "description": "Syntax highlighting for PDL (.pdl) files",
  "version": "0.1.0",
  "publisher": "curious-machines",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "pdl",
        "aliases": [
          "PDL",
          "Pixel Doodle Language"
        ],
        "extensions": [
          ".pdl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pdl",
        "scopeName": "source.pdl",
        "path": "./syntaxes/pdl.tmLanguage.json"
      }
    ]
  }
}
