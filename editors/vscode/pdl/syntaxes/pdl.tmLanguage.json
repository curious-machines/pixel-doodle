{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PDL",
  "scopeName": "source.pdl",
  "patterns": [
    { "include": "#comment" },
    { "include": "#kernel" },
    { "include": "#while-carry" },
    { "include": "#control" },
    { "include": "#statement" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.pdl"
    },
    "kernel": {
      "match": "\\b(kernel)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.declaration.kernel.pdl" },
        "2": { "name": "entity.name.function.pdl" }
      }
    },
    "while-carry": {
      "match": "\\b(while)\\s+(carry)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.control.while.pdl" },
        "2": { "name": "keyword.control.carry.pdl" }
      }
    },
    "control": {
      "patterns": [
        {
          "match": "\\b(emit|cond|yield)\\b",
          "name": "keyword.control.pdl"
        },
        {
          "match": "->",
          "name": "keyword.operator.arrow.pdl"
        }
      ]
    },
    "statement": {
      "patterns": [
        { "include": "#type" },
        { "include": "#operator" },
        { "include": "#constant" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#variable-def" }
      ]
    },
    "type": {
      "match": "\\b(f64|u32|bool)\\b",
      "name": "storage.type.pdl"
    },
    "operator": {
      "patterns": [
        {
          "match": "(?<==\\s*)\\b(add|sub|mul|div|rem|min|max|neg|abs|sqrt|floor|ceil)\\b",
          "name": "support.function.arithmetic.pdl"
        },
        {
          "match": "(?<==\\s*)\\b(bit_and|bit_or|bit_xor|shl|shr)\\b",
          "name": "support.function.bitwise.pdl"
        },
        {
          "match": "(?<==\\s*)\\b(and|or|not)\\b",
          "name": "support.function.logical.pdl"
        },
        {
          "match": "(?<==\\s*)\\b(eq|ne|lt|le|gt|ge)\\b",
          "name": "support.function.comparison.pdl"
        },
        {
          "match": "(?<==\\s*)\\b(f64_to_u32|u32_to_f64)\\b",
          "name": "support.function.conversion.pdl"
        },
        {
          "match": "(?<==\\s*)\\b(const|select|pack_argb)\\b",
          "name": "support.function.builtin.pdl"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "match": "\\b\\d+\\.\\d+\\b",
          "name": "constant.numeric.float.pdl"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.pdl"
        }
      ]
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.pdl"
    },
    "variable-def": {
      "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*:",
      "captures": {
        "1": { "name": "variable.other.pdl" }
      }
    }
  }
}
