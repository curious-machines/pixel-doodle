#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: ./run_all <category/example> [options]"
    echo ""
    echo "  Runs the example with all 4 render/codegen combos sequentially:"
    echo "    1. render=gpu  codegen=cranelift"
    echo "    2. render=gpu  codegen=llvm"
    echo "    3. render=cpu  codegen=cranelift"
    echo "    4. render=cpu  codegen=llvm"
    echo ""
    echo "  Extra arguments are passed through to each run."
    echo ""
    echo "Examples:"
    echo "  ./run_all basic/gradient"
    echo "  ./run_all sdf/cylinder_3d --set width=800,height=600"
    exit 1
}

[[ $# -lt 1 ]] && usage
[[ "$1" == "-h" || "$1" == "--help" ]] && usage

example="$1"
shift

configs=(
    "pipeline=gpu,render=gpu,codegen=cranelift"
    "pipeline=gpu,render=gpu,codegen=llvm"
    "pipeline=gpu,render=cpu,codegen=cranelift"
    "pipeline=gpu,render=cpu,codegen=llvm"
)

for combo in "${configs[@]}"; do
    echo "═══ $combo ═══"
    name=$(basename "$example")
    render="${combo#*render=}"; render="${render%%,*}"
    codegen="${combo#*codegen=}"; codegen="${codegen%%,*}"
    ./run "$example" --set "$combo,title=$name - $render/$codegen" "$@" || echo "  ⚠ exited with $?"
done
