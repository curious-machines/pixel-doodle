#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: ./run_all <category/example> [options]"
    echo ""
    echo "  Runs the example with all 3 GPU backends sequentially:"
    echo "    1. gpu"
    echo "    2. gpu-cranelift"
    echo "    3. gpu-llvm"
    echo ""
    echo "  Extra arguments are passed through to each run."
    echo ""
    echo "Examples:"
    echo "  ./run_all basic/gradient"
    echo "  ./run_all sdf/cylinder_3d --set width=800,height=600"
    exit 1
}

[[ $# -lt 1 ]] && usage
[[ "$1" == "-h" || "$1" == "--help" ]] && usage

example="$1"
shift

backends=(
    "pipeline=gpu,backend=gpu"
    "pipeline=gpu,backend=gpu-cranelift"
    "pipeline=gpu,backend=gpu-llvm"
)

for combo in "${backends[@]}"; do
    echo "═══ $combo ═══"
    # Extract pipeline and backend values for the window title.
    name=$(basename "$example")
    pip="${combo#*pipeline=}"; pip="${pip%%,*}"
    be="${combo#*backend=}"; be="${be%%,*}"
    ./run "$example" --set "$combo,title=$name - $pip/$be" "$@" || echo "  ⚠ exited with $?"
done
