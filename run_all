#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: ./run_all <example>"
    echo "  example: gradient, checkerboard, circle, etc."
    echo "  Launches all three backends (cranelift, llvm, gpu) simultaneously."
    exit 1
}

[[ $# -lt 1 ]] && usage

example="$1"

./run cranelift "$example" &
./run llvm "$example" &
./run gpu "$example" &
