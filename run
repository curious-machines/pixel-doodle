#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: ./run <backend> <example>"
    echo "  backend: cranelift, llvm, gpu"
    echo "  example: gradient, checkerboard, circle, etc."
    exit 1
}

[[ $# -lt 2 ]] && usage

backend="$1"
example="$2"

case "$backend" in
    cranelift)
        features="cranelift-backend"
        kernel="examples/${example}.pdl"
        ;;
    llvm)
        features="llvm-backend"
        kernel="examples/${example}.pdl"
        ;;
    gpu)
        features="cranelift-backend"  # need some default backend to compile
        kernel="examples/${example}.wgsl"
        ;;
    *)
        echo "Unknown backend: $backend"
        usage
        ;;
esac

if [[ ! -f "$kernel" ]]; then
    echo "Kernel file not found: $kernel"
    exit 1
fi

exec cargo run --release --no-default-features --features "$features" -- --backend "$backend" --kernel "$kernel"
