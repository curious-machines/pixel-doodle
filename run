#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: ./run <category/example> [--set key=val,...] [options]"
    echo ""
    echo "  category/example: basic/gradient, sim/smoke, sdf/gears, etc."
    echo ""
    echo "  Common --set values:"
    echo "    pipeline=pd|pdir|gpu       select pipeline (default: first in pdp)"
    echo "    backend=cranelift|llvm|gpu-cranelift|gpu-llvm"
    echo "    width=N height=N           window size"
    echo ""
    echo "  All extra arguments are passed through to pixel-doodle."
    echo ""
    echo "Examples:"
    echo "  ./run basic/gradient"
    echo "  ./run basic/mandelbrot --set pipeline=gpu"
    echo "  ./run sim/smoke --set pipeline=gpu,backend=gpu-cranelift"
    echo "  ./run sim/smoke --set pipeline=gpu,backend=gpu-llvm"
    echo "  ./run basic/gradient --set backend=llvm"
    exit 1
}

[[ $# -lt 1 ]] && usage
[[ "$1" == "-h" || "$1" == "--help" ]] && usage

example="$1"
shift

# Detect if llvm backend is requested to enable the right cargo feature.
features="cranelift-backend"
for arg in "$@"; do
    if [[ "$arg" == *"backend=llvm"* || "$arg" == *"backend=gpu-llvm"* ]]; then
        features="llvm-backend"
        # Ensure llvm-sys can find LLVM on macOS (Homebrew) and Linux
        if [[ -z "${LLVM_SYS_201_PREFIX:-}" ]]; then
            if command -v brew &>/dev/null; then
                llvm_prefix="$(brew --prefix llvm@20 2>/dev/null || brew --prefix llvm 2>/dev/null || true)"
                if [[ -n "$llvm_prefix" && -d "$llvm_prefix" ]]; then
                    export LLVM_SYS_201_PREFIX="$llvm_prefix"
                fi
            fi
        fi
        break
    fi
done

exec cargo run --release --no-default-features --features "$features" -- "examples/${example}" "$@"
